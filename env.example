# ShopC2C Secure Payment Gateway - Environment Variables Template
# Copy this file to .env.local and fill in your actual values

# ============================================
# Appwrite Configuration (Required)
# ============================================
# These are REQUIRED for authentication, database, and storage.

# Appwrite API Endpoint
NEXT_PUBLIC_APPWRITE_ENDPOINT=https://cloud.appwrite.io/v1

# Appwrite Project ID
NEXT_PUBLIC_APPWRITE_PROJECT_ID=your_project_id_here

# Appwrite Database ID
APPWRITE_DATABASE_ID=your_database_id_here

# Appwrite Storage Bucket ID
APPWRITE_BUCKET_ID=your_bucket_id_here

# Appwrite API Key (Optional for some tasks, but recommended for full backend access)
APPWRITE_API_KEY=your_appwrite_api_key_here

# ============================================
# AI Verification (Optional)
# ============================================
# Required only if using AI-powered screenshot verification
# Get from: https://makersuite.google.com/app/apikey

GEMINI_API_KEY=your_google_gemini_api_key_here

# ============================================
# Local Setup
# ============================================
API_SERVER_URL=http://localhost:5173
NEXT_PUBLIC_BASE_URL=http://localhost:5173

# ============================================
# Notes:
# ============================================
# 1. For Vercel deployment, add these same variables in Vercel Dashboard → Settings → Environment Variables
# 2. Never commit .env.local to git (it's already in .gitignore)
