# ShopC2C Secure Payment Gateway - Environment Variables Template
# Copy this file to .env.local and fill in your actual values

# ============================================
# Firebase Admin SDK (Server-side - REQUIRED)
# ============================================
# These are REQUIRED for database connections in API routes
# Get these from Firebase Console → Project Settings → Service Accounts → Generate New Private Key

FIREBASE_PROJECT_ID=your_project_id_here
FIREBASE_CLIENT_EMAIL=your_service_account_email@your-project.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYour\nPrivate\nKey\nHere\n-----END PRIVATE KEY-----\n"
FIREBASE_STORAGE_BUCKET=your_project.appspot.com

# ============================================
# Firebase Client SDK (Frontend - Optional)
# ============================================
# Only needed if you're using client-side Firebase features
# Get these from Firebase Console → Project Settings → General → Your apps

VITE_FIREBASE_API_KEY=your_api_key_here
VITE_FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your_project_id_here
VITE_FIREBASE_STORAGE_BUCKET=your_project.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=your_sender_id_here
VITE_FIREBASE_APP_ID=your_app_id_here

# ============================================
# AI Verification (Optional)
# ============================================
# Required only if using AI-powered screenshot verification
# Get from: https://makersuite.google.com/app/apikey

GEMINI_API_KEY=your_google_gemini_api_key_here

# ============================================
# Notes:
# ============================================
# 1. For Vercel deployment, add these same variables in Vercel Dashboard → Settings → Environment Variables
# 2. The FIREBASE_PRIVATE_KEY should be the full key from your service account JSON file
# 3. In .env.local, you can use \n for newlines in the private key
# 4. In Vercel, paste the private key with actual newlines or use \n characters
# 5. Never commit .env.local to git (it's already in .gitignore)

