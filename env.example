# ShopC2C Secure Payment Gateway - Astro & Prisma Template
# Copy this file to .env.local and fill in your actual values

# ============================================
# Database Configuration (Neon PostgreSQL)
# ============================================
# Connect to your Neon PostgreSQL database via Prisma
DATABASE_URL=database-url

# ============================================
# AI Verification (Google Gemini)
# ============================================
# Get from: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_google_gemini_api_key_here

# ============================================
# Admin Authentication
# ============================================
# PIN used to access the /admin dashboard
ADMIN_PIN=1234

# ============================================
# Base URLs
# ============================================
# Local development: http://localhost:4321
# Production: your-site-url.vercel.app
NEXT_PUBLIC_BASE_URL=http://localhost:4321

# ============================================
# Deployment Notes:
# ============================================
# 1. For Vercel, add DATABASE_URL, GEMINI_API_KEY, and ADMIN_PIN to Vercel Settings.
# 2. Run 'npx prisma generate' after setting DATABASE_URL.
# 3. Run 'npx prisma db push' to sync schema to Neon DB.
