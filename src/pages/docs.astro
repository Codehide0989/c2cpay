---
import MainLayout from "../layouts/MainLayout.astro";
---

<MainLayout title="ShopC2C - API Documentation">
    <div
        class="min-h-screen w-full relative font-sans selection:bg-neon-blue selection:text-black overflow-x-hidden"
    >
        <!-- Background Effects -->
        <div class="fixed inset-0 pointer-events-none z-[-1]">
            <div
                class="absolute top-[10%] left-[-5%] w-[80%] md:w-[40%] h-[40%] bg-neon-blue/5 rounded-full blur-[80px] md:blur-[120px] animate-pulse"
            >
            </div>
            <div
                class="absolute bottom-[10%] right-[-5%] w-[80%] md:w-[40%] h-[40%] bg-neon-purple/5 rounded-full blur-[80px] md:blur-[120px] animate-pulse"
                style="animation-delay: 2s"
            >
            </div>
            <div
                class="absolute inset-0 bg-[url('https://www.transparenttextures.com/patterns/carbon-fibre.png')] opacity-[0.03]"
            >
            </div>
        </div>

        <!-- Navbar -->
        <nav
            class="fixed top-0 left-0 w-full px-4 sm:px-6 md:px-10 py-3 sm:py-4 flex justify-between items-center z-50 bg-slate-950/80 backdrop-blur-xl border-b border-white/5"
        >
            <a
                href="/"
                class="flex items-center gap-3 md:gap-4 font-sans group"
            >
                <div class="relative">
                    <div
                        class="absolute -inset-1 bg-gradient-to-r from-neon-blue to-neon-purple rounded-full blur opacity-40 group-hover:opacity-100 transition duration-1000"
                    >
                    </div>
                    <div
                        class="relative w-8 h-8 md:w-10 md:h-10 bg-slate-900 rounded-full flex items-center justify-center border border-white/10"
                    >
                        <svg
                            class="w-4 h-4 md:w-5 md:h-5 text-neon-blue fill-neon-blue/20"
                            viewBox="0 0 24 24"
                            fill="currentColor"
                            stroke="currentColor"
                            stroke-width="2"
                            ><path
                                d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"
                            ></path></svg
                        >
                    </div>
                </div>
                <div class="flex flex-col">
                    <span
                        class="text-base md:text-xl font-black tracking-tighter text-white leading-none"
                        >ShopC2C</span
                    >
                    <span
                        class="text-[8px] md:text-[10px] font-black uppercase tracking-[0.2em] text-slate-500 mt-0.5"
                        >Documentation</span
                    >
                </div>
            </a>
            <div class="flex items-center gap-2">
                <a
                    href="/"
                    class="text-[10px] md:text-xs font-bold uppercase tracking-widest text-slate-400 hover:text-white transition px-3 py-2"
                    >Home</a
                >
                <a
                    href="/admin"
                    class="group relative flex items-center gap-2 bg-slate-900/80 hover:bg-slate-800 border border-white/10 rounded-xl px-3 md:px-4 py-2 transition-all active:scale-95"
                >
                    <span
                        class="text-[10px] md:text-xs font-black uppercase tracking-widest text-white"
                        >Dashboard</span
                    >
                </a>
            </div>
        </nav>

        <!-- Hero Section -->
        <header
            class="w-full pt-24 sm:pt-28 md:pt-32 pb-10 sm:pb-14 px-4 sm:px-6 md:px-10 lg:px-20 text-center"
        >
            <div
                class="inline-flex items-center gap-3 px-4 py-2 rounded-2xl border border-neon-blue/20 bg-neon-blue/5 text-neon-blue text-[10px] md:text-xs font-black tracking-[0.2em] uppercase backdrop-blur-sm mb-6"
            >
                <div class="w-2 h-2 rounded-full bg-neon-blue animate-pulse">
                </div>
                Developer Docs v4.0
            </div>
            <h1
                class="text-3xl sm:text-4xl md:text-5xl lg:text-6xl font-black text-white tracking-tighter leading-[0.95] mb-4"
            >
                API <span
                    class="bg-clip-text text-transparent bg-gradient-to-r from-neon-blue via-indigo-400 to-neon-purple"
                    >Documentation</span
                >
            </h1>
            <p
                class="text-slate-400 text-sm sm:text-base md:text-lg max-w-2xl mx-auto leading-relaxed"
            >
                Integrate ShopC2C's secure UPI payment gateway into your
                application in minutes. <span class="text-neon-blue font-bold"
                    >No API key required</span
                > — just use URL parameters to get started.
            </p>
        </header>

        <!-- Docs Content -->
        <main class="w-full px-4 sm:px-6 md:px-10 lg:px-20 pb-20">
            <div class="max-w-5xl mx-auto space-y-6 md:space-y-8">
                <!-- Quick Start -->
                <section class="doc-card group">
                    <div class="flex items-center gap-3 mb-4">
                        <div
                            class="w-8 h-8 rounded-lg bg-neon-blue/10 flex items-center justify-center border border-neon-blue/20"
                        >
                            <svg
                                class="w-4 h-4 text-neon-blue"
                                fill="none"
                                stroke="currentColor"
                                viewBox="0 0 24 24"
                                ><path
                                    stroke-linecap="round"
                                    stroke-linejoin="round"
                                    stroke-width="2"
                                    d="M13 10V3L4 14h7v7l9-11h-7z"></path></svg
                            >
                        </div>
                        <h2
                            class="text-lg sm:text-xl md:text-2xl font-black text-white tracking-tight"
                        >
                            Quick Start
                        </h2>
                    </div>
                    <p class="text-slate-400 text-sm md:text-base mb-4">
                        Generate a payment link by passing URL parameters to the
                        gateway endpoint:
                    </p>
                    <div class="code-block">
                        <div
                            class="flex items-center justify-between px-4 py-2 bg-white/5 border-b border-white/5 rounded-t-xl"
                        >
                            <span
                                class="text-[10px] font-bold uppercase tracking-widest text-slate-500"
                                >Payment URL</span
                            >
                            <button
                                onclick="navigator.clipboard.writeText(this.closest('.code-block').querySelector('code').textContent)"
                                class="text-[10px] font-bold uppercase tracking-widest text-neon-blue hover:text-white transition cursor-pointer"
                                >Copy</button
                            >
                        </div>
                        <pre
                            class="p-4 overflow-x-auto text-sm"><code class="text-emerald-400">https://c2cpay.vercel.app/?pa=store@upi&pn=MyStore&am=500&locked=true&redirect_url=https://myshop.com/success</code></pre>
                    </div>
                </section>

                <!-- No API Key Required Alert -->
                <section
                    class="doc-card group"
                    style="border-color: rgba(16, 185, 129, 0.2); background: rgba(16, 185, 129, 0.03);"
                >
                    <div class="flex items-center gap-3 mb-4">
                        <div
                            class="w-8 h-8 rounded-lg bg-emerald-500/10 flex items-center justify-center border border-emerald-500/20"
                        >
                            <svg
                                class="w-4 h-4 text-emerald-400"
                                fill="none"
                                stroke="currentColor"
                                viewBox="0 0 24 24"
                                ><path
                                    stroke-linecap="round"
                                    stroke-linejoin="round"
                                    stroke-width="2"
                                    d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"
                                ></path></svg
                            >
                        </div>
                        <h2
                            class="text-lg sm:text-xl md:text-2xl font-black text-emerald-400 tracking-tight"
                        >
                            No API Key Needed
                        </h2>
                    </div>
                    <p class="text-slate-300 text-sm md:text-base mb-4">
                        ShopC2C works <strong class="text-white"
                            >without any API key integration</strong
                        >. Simply construct a payment URL with your UPI VPA and
                        query parameters — no signup, no authentication token,
                        no server-side setup required.
                    </p>
                    <div class="grid grid-cols-1 sm:grid-cols-3 gap-3">
                        <div
                            class="flex items-center gap-2 bg-emerald-500/5 border border-emerald-500/10 rounded-xl p-3"
                        >
                            <svg
                                class="w-4 h-4 text-emerald-400 shrink-0"
                                fill="none"
                                stroke="currentColor"
                                viewBox="0 0 24 24"
                                ><path
                                    stroke-linecap="round"
                                    stroke-linejoin="round"
                                    stroke-width="2"
                                    d="M5 13l4 4L19 7"></path></svg
                            >
                            <span class="text-xs text-slate-300 font-bold"
                                >No API Key</span
                            >
                        </div>
                        <div
                            class="flex items-center gap-2 bg-emerald-500/5 border border-emerald-500/10 rounded-xl p-3"
                        >
                            <svg
                                class="w-4 h-4 text-emerald-400 shrink-0"
                                fill="none"
                                stroke="currentColor"
                                viewBox="0 0 24 24"
                                ><path
                                    stroke-linecap="round"
                                    stroke-linejoin="round"
                                    stroke-width="2"
                                    d="M5 13l4 4L19 7"></path></svg
                            >
                            <span class="text-xs text-slate-300 font-bold"
                                >No Server Setup</span
                            >
                        </div>
                        <div
                            class="flex items-center gap-2 bg-emerald-500/5 border border-emerald-500/10 rounded-xl p-3"
                        >
                            <svg
                                class="w-4 h-4 text-emerald-400 shrink-0"
                                fill="none"
                                stroke="currentColor"
                                viewBox="0 0 24 24"
                                ><path
                                    stroke-linecap="round"
                                    stroke-linejoin="round"
                                    stroke-width="2"
                                    d="M5 13l4 4L19 7"></path></svg
                            >
                            <span class="text-xs text-slate-300 font-bold"
                                >Just URL Params</span
                            >
                        </div>
                    </div>
                </section>

                <!-- Parameters Table -->
                <section class="doc-card">
                    <div class="flex items-center gap-3 mb-4">
                        <div
                            class="w-8 h-8 rounded-lg bg-neon-purple/10 flex items-center justify-center border border-neon-purple/20"
                        >
                            <svg
                                class="w-4 h-4 text-neon-purple"
                                fill="none"
                                stroke="currentColor"
                                viewBox="0 0 24 24"
                                ><path
                                    stroke-linecap="round"
                                    stroke-linejoin="round"
                                    stroke-width="2"
                                    d="M4 6h16M4 12h16M4 18h7"></path></svg
                            >
                        </div>
                        <h2
                            class="text-lg sm:text-xl md:text-2xl font-black text-white tracking-tight"
                        >
                            URL Parameters
                        </h2>
                    </div>
                    <div class="overflow-x-auto -mx-4 sm:mx-0">
                        <table class="w-full text-left text-sm">
                            <thead>
                                <tr class="border-b border-white/10">
                                    <th
                                        class="px-4 py-3 text-[10px] md:text-xs font-black uppercase tracking-widest text-slate-500"
                                        >Param</th
                                    >
                                    <th
                                        class="px-4 py-3 text-[10px] md:text-xs font-black uppercase tracking-widest text-slate-500"
                                        >Type</th
                                    >
                                    <th
                                        class="px-4 py-3 text-[10px] md:text-xs font-black uppercase tracking-widest text-slate-500"
                                        >Required</th
                                    >
                                    <th
                                        class="px-4 py-3 text-[10px] md:text-xs font-black uppercase tracking-widest text-slate-500"
                                        >Description</th
                                    >
                                </tr>
                            </thead>
                            <tbody class="text-slate-300">
                                <tr
                                    class="border-b border-white/5 hover:bg-white/[0.02] transition"
                                    ><td class="px-4 py-3"
                                        ><code
                                            class="text-neon-blue text-xs font-bold"
                                            >pa</code
                                        ></td
                                    ><td class="px-4 py-3 text-xs">string</td
                                    ><td class="px-4 py-3"
                                        ><span
                                            class="text-emerald-400 text-xs font-bold"
                                            >Yes</span
                                        ></td
                                    ><td
                                        class="px-4 py-3 text-xs text-slate-400"
                                        >Merchant UPI VPA (e.g. store@upi)</td
                                    ></tr
                                >
                                <tr
                                    class="border-b border-white/5 hover:bg-white/[0.02] transition"
                                    ><td class="px-4 py-3"
                                        ><code
                                            class="text-neon-blue text-xs font-bold"
                                            >pn</code
                                        ></td
                                    ><td class="px-4 py-3 text-xs">string</td
                                    ><td class="px-4 py-3"
                                        ><span
                                            class="text-emerald-400 text-xs font-bold"
                                            >Yes</span
                                        ></td
                                    ><td
                                        class="px-4 py-3 text-xs text-slate-400"
                                        >Merchant / Payee name</td
                                    ></tr
                                >
                                <tr
                                    class="border-b border-white/5 hover:bg-white/[0.02] transition"
                                    ><td class="px-4 py-3"
                                        ><code
                                            class="text-neon-blue text-xs font-bold"
                                            >am</code
                                        ></td
                                    ><td class="px-4 py-3 text-xs">number</td
                                    ><td class="px-4 py-3"
                                        ><span
                                            class="text-amber-400 text-xs font-bold"
                                            >Optional</span
                                        ></td
                                    ><td
                                        class="px-4 py-3 text-xs text-slate-400"
                                        >Fixed payment amount in INR</td
                                    ></tr
                                >
                                <tr
                                    class="border-b border-white/5 hover:bg-white/[0.02] transition"
                                    ><td class="px-4 py-3"
                                        ><code
                                            class="text-neon-blue text-xs font-bold"
                                            >tn</code
                                        ></td
                                    ><td class="px-4 py-3 text-xs">string</td
                                    ><td class="px-4 py-3"
                                        ><span
                                            class="text-amber-400 text-xs font-bold"
                                            >Optional</span
                                        ></td
                                    ><td
                                        class="px-4 py-3 text-xs text-slate-400"
                                        >Transaction note / description</td
                                    ></tr
                                >
                                <tr
                                    class="border-b border-white/5 hover:bg-white/[0.02] transition"
                                    ><td class="px-4 py-3"
                                        ><code
                                            class="text-neon-blue text-xs font-bold"
                                            >locked</code
                                        ></td
                                    ><td class="px-4 py-3 text-xs">boolean</td
                                    ><td class="px-4 py-3"
                                        ><span
                                            class="text-amber-400 text-xs font-bold"
                                            >Optional</span
                                        ></td
                                    ><td
                                        class="px-4 py-3 text-xs text-slate-400"
                                        >Lock amount (user cannot change)</td
                                    ></tr
                                >
                                <tr class="hover:bg-white/[0.02] transition"
                                    ><td class="px-4 py-3"
                                        ><code
                                            class="text-neon-blue text-xs font-bold"
                                            >redirect_url</code
                                        ></td
                                    ><td class="px-4 py-3 text-xs">string</td
                                    ><td class="px-4 py-3"
                                        ><span
                                            class="text-amber-400 text-xs font-bold"
                                            >Optional</span
                                        ></td
                                    ><td
                                        class="px-4 py-3 text-xs text-slate-400"
                                        >Redirect URL after successful payment</td
                                    ></tr
                                >
                            </tbody>
                        </table>
                    </div>
                </section>

                <!-- API Endpoints -->
                <section class="doc-card">
                    <div class="flex items-center gap-3 mb-4">
                        <div
                            class="w-8 h-8 rounded-lg bg-emerald-500/10 flex items-center justify-center border border-emerald-500/20"
                        >
                            <svg
                                class="w-4 h-4 text-emerald-400"
                                fill="none"
                                stroke="currentColor"
                                viewBox="0 0 24 24"
                                ><path
                                    stroke-linecap="round"
                                    stroke-linejoin="round"
                                    stroke-width="2"
                                    d="M5 12h14M12 5l7 7-7 7"></path></svg
                            >
                        </div>
                        <h2
                            class="text-lg sm:text-xl md:text-2xl font-black text-white tracking-tight"
                        >
                            API Endpoints
                        </h2>
                    </div>
                    <div class="space-y-3">
                        <div class="endpoint-row">
                            <span
                                class="method-badge bg-emerald-500/20 text-emerald-400"
                                >GET</span
                            >
                            <code class="text-sm text-slate-300 flex-1"
                                >/api/status</code
                            >
                            <span
                                class="text-xs text-slate-500 hidden sm:inline"
                                >Health check &amp; gateway status</span
                            >
                        </div>
                        <div class="endpoint-row">
                            <span
                                class="method-badge bg-amber-500/20 text-amber-400"
                                >POST</span
                            >
                            <code class="text-sm text-slate-300 flex-1"
                                >/api/verify</code
                            >
                            <span
                                class="text-xs text-slate-500 hidden sm:inline"
                                >Verify payment via UTR or screenshot</span
                            >
                        </div>
                        <div class="endpoint-row">
                            <span
                                class="method-badge bg-amber-500/20 text-amber-400"
                                >POST</span
                            >
                            <code class="text-sm text-slate-300 flex-1"
                                >/api/payment</code
                            >
                            <span
                                class="text-xs text-slate-500 hidden sm:inline"
                                >Log a new payment transaction</span
                            >
                        </div>
                        <div class="endpoint-row">
                            <span
                                class="method-badge bg-neon-blue/20 text-neon-blue"
                                >GET</span
                            >
                            <code class="text-sm text-slate-300 flex-1"
                                >/api/config</code
                            >
                            <span
                                class="text-xs text-slate-500 hidden sm:inline"
                                >Fetch current gateway configuration</span
                            >
                        </div>
                        <div class="endpoint-row">
                            <span
                                class="method-badge bg-amber-500/20 text-amber-400"
                                >POST</span
                            >
                            <code class="text-sm text-slate-300 flex-1"
                                >/api/config</code
                            >
                            <span
                                class="text-xs text-slate-500 hidden sm:inline"
                                >Update gateway configuration (admin)</span
                            >
                        </div>
                        <div class="endpoint-row">
                            <span
                                class="method-badge bg-neon-blue/20 text-neon-blue"
                                >GET</span
                            >
                            <code class="text-sm text-slate-300 flex-1"
                                >/api/stats</code
                            >
                            <span
                                class="text-xs text-slate-500 hidden sm:inline"
                                >Dashboard analytics &amp; KPIs</span
                            >
                        </div>
                    </div>
                </section>

                <!-- Verify Endpoint Detail -->
                <section class="doc-card">
                    <div class="flex items-center gap-3 mb-4">
                        <div
                            class="w-8 h-8 rounded-lg bg-amber-500/10 flex items-center justify-center border border-amber-500/20"
                        >
                            <svg
                                class="w-4 h-4 text-amber-400"
                                fill="none"
                                stroke="currentColor"
                                viewBox="0 0 24 24"
                                ><path
                                    stroke-linecap="round"
                                    stroke-linejoin="round"
                                    stroke-width="2"
                                    d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"
                                ></path></svg
                            >
                        </div>
                        <h2
                            class="text-lg sm:text-xl md:text-2xl font-black text-white tracking-tight"
                        >
                            Payment Verification
                        </h2>
                    </div>
                    <p class="text-slate-400 text-sm md:text-base mb-4">
                        Two verification methods available:
                    </p>
                    <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                        <div
                            class="bg-white/[0.02] rounded-xl border border-white/5 p-4"
                        >
                            <h3
                                class="text-sm font-bold text-white mb-2 flex items-center gap-2"
                            >
                                <span
                                    class="w-5 h-5 rounded bg-neon-blue/20 text-neon-blue text-[10px] font-black flex items-center justify-center"
                                    >1</span
                                >
                                UTR Verification
                            </h3>
                            <div class="code-block text-xs">
                                <pre
                                    class="p-3 overflow-x-auto"><code class="text-emerald-400">POST /api/verify
Content-Type: application/json

{"{"}
  "method": "utr",
  "utr": "412345678901",
  "amount": "500",
  "pa": "store@upi"
{"}"}</code></pre>
                            </div>
                        </div>
                        <div
                            class="bg-white/[0.02] rounded-xl border border-white/5 p-4"
                        >
                            <h3
                                class="text-sm font-bold text-white mb-2 flex items-center gap-2"
                            >
                                <span
                                    class="w-5 h-5 rounded bg-neon-purple/20 text-neon-purple text-[10px] font-black flex items-center justify-center"
                                    >2</span
                                >
                                AI Screenshot Verification
                            </h3>
                            <div class="code-block text-xs">
                                <pre
                                    class="p-3 overflow-x-auto"><code class="text-emerald-400">POST /api/verify
Content-Type: application/json

{"{"}
  "method": "screenshot",
  "screenshot": "data:image/...",
  "amount": "500",
  "pa": "store@upi"
{"}"}</code></pre>
                            </div>
                        </div>
                    </div>
                </section>

                <!-- Integration Examples -->
                <section class="doc-card">
                    <div class="flex items-center gap-3 mb-4">
                        <div
                            class="w-8 h-8 rounded-lg bg-indigo-500/10 flex items-center justify-center border border-indigo-500/20"
                        >
                            <svg
                                class="w-4 h-4 text-indigo-400"
                                fill="none"
                                stroke="currentColor"
                                viewBox="0 0 24 24"
                                ><path
                                    stroke-linecap="round"
                                    stroke-linejoin="round"
                                    stroke-width="2"
                                    d="M10 20l4-16m4 4l4 4-4 4M6 16l-4-4 4-4"
                                ></path></svg
                            >
                        </div>
                        <h2
                            class="text-lg sm:text-xl md:text-2xl font-black text-white tracking-tight"
                        >
                            Integration Examples
                        </h2>
                    </div>
                    <div
                        class="bg-neon-blue/5 border border-neon-blue/10 rounded-xl p-3 mb-4"
                    >
                        <p
                            class="text-neon-blue text-xs font-bold flex items-center gap-2"
                        >
                            <svg
                                class="w-3.5 h-3.5 shrink-0"
                                fill="none"
                                stroke="currentColor"
                                viewBox="0 0 24 24"
                                ><path
                                    stroke-linecap="round"
                                    stroke-linejoin="round"
                                    stroke-width="2"
                                    d="M13 16h-1v-4h-1m1-4h.01M21 12a10.968 10.968 0 01-2 6.291A10.97 10.97 0 0112 22 10.97 10.97 0 013 18.291 10.968 10.968 0 011 12C1 5.925 5.925 1 12 1s11 4.925 11 11z"
                                ></path></svg
                            >
                            These examples work without any API key — just copy and
                            use!
                        </p>
                    </div>
                    <div class="space-y-4">
                        <div>
                            <h3
                                class="text-xs font-black uppercase tracking-widest text-slate-500 mb-2"
                            >
                                HTML / Redirect
                            </h3>
                            <div class="code-block">
                                <pre
                                    class="p-4 overflow-x-auto text-xs"><code class="text-emerald-400">&lt;a href="https://c2cpay.vercel.app/?pa=shop@upi&amp;pn=MyShop&amp;am=299&amp;locked=true&amp;redirect_url=https://myshop.com/thanks"&gt;
  Pay ₹299
