---
import MainLayout from "../layouts/MainLayout.astro";
import PaymentCard from "../components/PaymentCard.astro";
import MaintenanceView from "../components/MaintenanceView.astro";

// Config fetched via Astro server-side
import { prisma } from "../lib/prisma";
const configRecord = await prisma.config.findUnique({
    where: { id: "singleton" },
});

// Default config if DB empty
const config = {
    pa: configRecord?.pa || "shopc2c@upi",
    pn: configRecord?.pn || "ShopC2C Store",
    tn: configRecord?.tn || "Order Payment",
    am: configRecord?.am || "0",
    title: configRecord?.title || "Secure Payment",
    amountLocked: configRecord?.amountLocked || false,
    redirectUrl: configRecord?.redirectUrl || "",
    maintenanceMode: configRecord?.maintenanceMode || false,
    maintenanceMessage: configRecord?.maintenanceMessage || "",
    maintenanceEndTime: configRecord?.maintenanceEndTime || null,
};
---

<MainLayout title={config.title || "Secure Payment"}>
    {config.maintenanceMode ? (
        <MaintenanceView
            message={config.maintenanceMessage}
            endTime={config.maintenanceEndTime}
        />
    ) : (
        <div class="min-h-screen w-full flex flex-col items-center justify-center p-3 sm:p-4 md:p-8 relative font-sans selection:bg-neon-blue selection:text-black overflow-x-hidden">
            <!-- Hero Background Elements -->
            <div class="fixed inset-0 pointer-events-none z-[-1]">
                <div class="absolute top-[10%] left-[-5%] w-[80%] md:w-[40%] h-[40%] bg-neon-blue/5 rounded-full blur-[80px] md:blur-[120px] animate-pulse"></div>
                <div class="absolute bottom-[10%] right-[-5%] w-[80%] md:w-[40%] h-[40%] bg-neon-purple/5 rounded-full blur-[80px] md:blur-[120px] animate-pulse" style="animation-delay: 2s"></div>
                <div class="absolute inset-0 bg-[url('https://www.transparenttextures.com/patterns/carbon-fibre.png')] opacity-[0.03]"></div>
            </div>

            <!-- Navbar Minimal -->
            <nav class="fixed top-0 left-0 w-full p-3 sm:p-4 md:p-8 flex justify-between items-center z-50 animate-in fade-in slide-in-from-top-4 duration-1000 bg-slate-950/70 md:bg-transparent backdrop-blur-lg md:backdrop-blur-none border-b border-white/5 md:border-none">
                <div class="flex items-center gap-3 md:gap-4 font-sans">
                    <div class="relative group">
                        <div class="absolute -inset-1 bg-gradient-to-r from-neon-blue to-neon-purple rounded-full blur opacity-40 group-hover:opacity-100 transition duration-1000"></div>
                        <div class="relative w-8 h-8 md:w-10 md:h-10 bg-slate-900 rounded-full flex items-center justify-center border border-white/10">
                            <!-- Shield Icon -->
                            <svg class="w-4 h-4 md:w-5 md:h-5 text-neon-blue fill-neon-blue/20" viewBox="0 0 24 24" fill="currentColor" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
                        </div>
                    </div>
                    <div class="flex flex-col">
                        <span class="text-lg md:text-xl font-black tracking-tighter text-white leading-none">ShopC2C</span>
                        <span class="text-[8px] md:text-[10px] font-black uppercase tracking-[0.2em] text-slate-500 mt-0.5 md:mt-1">Merchant Node</span>
                    </div>
                </div>

                <div class="flex items-center gap-2 md:gap-6">
                    <a href="/admin" class="group relative flex items-center gap-2 md:gap-3 bg-slate-900/80 hover:bg-slate-800 backdrop-blur-xl border border-white/10 rounded-xl md:rounded-2xl px-3 md:px-5 py-2 md:py-2.5 transition-all active:scale-95 overflow-hidden font-sans">
                        <div class="absolute inset-0 bg-gradient-to-r from-neon-blue/10 to-transparent opacity-0 group-hover:opacity-100 transition-opacity"></div>
                        <!-- LayoutDashboard Icon -->
                        <svg class="w-4 h-4 md:w-5 md:h-5 text-slate-400 group-hover:text-white md:group-hover:rotate-90 transition-all duration-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4h6v6H4zm10 0h6v6h-6zm-10 10h6v6H4zm10 0h6v6h-6z"/></svg>
                        <span class="text-[10px] md:text-sm font-black uppercase tracking-widest text-white">Dashboard</span>
                    </a>
                </div>
            </nav>

            <!-- Main Payment View -->
            <main class="w-full max-w-7xl mx-auto flex flex-col lg:grid lg:grid-cols-2 items-center justify-center gap-8 sm:gap-12 lg:gap-16 z-10 pt-24 sm:pt-28 pb-16 sm:pb-10 md:pt-32 lg:pt-0">
                <div class="flex flex-col items-center lg:items-start gap-6 md:gap-8 max-w-xl animate-in fade-in slide-in-from-left-8 duration-1000 text-center lg:text-left px-4">
                    <div class="inline-flex items-center gap-3 px-4 py-2 rounded-2xl border border-neon-blue/20 bg-neon-blue/5 text-neon-blue text-[10px] md:text-xs font-black tracking-[0.2em] uppercase backdrop-blur-sm">
                        <div class="w-2 h-2 rounded-full bg-neon-blue animate-pulse"></div>
                        Secure Gateway Node 4.0
                    </div>
                    <div class="space-y-4">
                        <h1 class="text-3xl sm:text-5xl md:text-7xl lg:text-8xl font-black text-white tracking-tighter leading-[0.9]">
                            {config.title || "SECURE"} <br />
                            <span class="bg-clip-text text-transparent bg-gradient-to-r from-neon-blue via-indigo-400 to-neon-purple">PAYMENT</span>
                        </h1>
                        <p class="text-slate-400 text-base md:text-lg lg:text-xl font-medium leading-relaxed max-w-md italic opacity-80 mx-auto lg:mx-0 font-sans">
                            "{config.pn || 'ShopC2C Store'} is processing this transaction through a cryptographically secured peer-to-peer node."
                        </p>
                    </div>

                    <div class="grid grid-cols-2 gap-4 md:gap-8 w-full border-t border-slate-800 pt-8">
                        <div>
                            <p class="text-[8px] md:text-[10px] font-black uppercase tracking-widest text-slate-600 mb-2">Carrier Layer</p>
                            <p class="text-sm md:text-lg font-bold text-white flex items-center justify-center lg:justify-start gap-2">
                                HTTP/3 Edge 
                                <svg class="w-3 h-3 md:w-4 md:h-4 text-neon-blue" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm1 15h-2v-2h2v2zm0-4h-2V7h2v6z"/></svg>
                            </p>
                        </div>
                        <div>
                            <p class="text-[8px] md:text-[10px] font-black uppercase tracking-widest text-slate-600 mb-2">Protocol</p>
                            <p class="text-sm md:text-lg font-bold text-white flex items-center justify-center lg:justify-start gap-2">
                                UPI Direct 
                                <svg class="w-3 h-3 md:w-4 md:h-4 text-amber-400" viewBox="0 0 24 24" fill="currentColor"><path d="M13 10V3L4 14h7v7l9-11h-7z"/></svg>
                            </p>
                        </div>
                    </div>
                </div>

                <div class="w-full flex justify-center lg:justify-end animate-in fade-in slide-in-from-right-8 duration-1000">
                    <PaymentCard config={{
                        pa: config.pa,
                        pn: config.pn,
                        tn: config.tn,
                        am: config.am,
                        amountLocked: config.amountLocked,
                        redirectUrl: config.redirectUrl,
                    }} />
                </div>
            </main>
        </div>
    )}
</MainLayout>
