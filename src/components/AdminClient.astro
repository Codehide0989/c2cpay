---
/// <reference types="astro/client" />
// AdminClient.astro
import IntegrationDocs from "./IntegrationDocs.astro";
---

<div
    id="authContainer"
    class="max-w-md mx-auto mt-20 p-10 bg-slate-900/80 backdrop-blur-xl border border-white/10 rounded-[2.5rem] shadow-[0_0_50px_-12px_rgba(0,243,255,0.2)] flex flex-col items-center animate-in fade-in zoom-in duration-700"
>
    <!-- Modern Shield Icon -->
    <div class="relative mb-8 group">
        <div
            class="absolute -inset-4 bg-neon-blue/20 rounded-full blur-2xl group-hover:bg-neon-blue/30 transition-all duration-500"
        >
        </div>
        <div
            class="relative w-20 h-20 bg-slate-800 rounded-3xl flex items-center justify-center border border-white/10 shadow-inner group-hover:scale-110 transition-transform duration-500"
        >
            <svg
                class="w-10 h-10 text-neon-blue"
                fill="none"
                stroke="currentColor"
                viewBox="0 0 24 24"
                stroke-width="2"
            >
                <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"
                ></path>
            </svg>
        </div>
    </div>

    <div class="text-center mb-8">
        <h2 class="text-3xl font-black text-white tracking-tighter mb-2">
            RESTRICTED
        </h2>
        <p class="text-slate-500 text-xs font-bold uppercase tracking-[0.2em]">
            Administrative Interface
        </p>
    </div>

    <div class="w-full space-y-4">
        <div class="relative">
            <input
                type="password"
                id="adminPinInput"
                placeholder="••••"
                maxlength="4"
                class="w-full bg-slate-800/50 border border-white/5 p-5 rounded-2xl text-center text-3xl text-white tracking-[0.5em] focus:border-neon-blue/50 focus:ring-4 focus:ring-neon-blue/10 outline-none transition-all placeholder:text-slate-700"
            />
            <div
                class="absolute inset-y-0 right-4 flex items-center pointer-events-none opacity-20"
            >
                <svg
                    class="w-5 h-5 text-white"
                    fill="none"
                    stroke="currentColor"
                    viewBox="0 0 24 24"
                    ><path
                        d="M15 7a2 2 0 012 2m4 0a6 6 0 01-7.743 5.743L11 17H9v2H7v2H4a1 1 0 01-1-1v-2.586a1 1 0 01.293-.707l5.964-5.964A6 6 0 1121 9z"
                        stroke-width="2"
                        stroke-linecap="round"
                        stroke-linejoin="round"></path></svg
                >
            </div>
        </div>

        <p
            id="authErrorMsg"
            class="text-rose-400 text-xs font-bold text-center hidden animate-pulse"
        >
        </p>

        <button
            id="unlockBtn"
            class="group w-full relative overflow-hidden bg-white text-black font-black py-5 rounded-2xl hover:scale-[1.02] active:scale-[0.98] transition-all duration-300"
        >
            <div
                class="absolute inset-0 bg-gradient-to-r from-neon-blue to-neon-purple opacity-0 group-hover:opacity-10 transition-opacity"
            >
            </div>
            <span class="relative z-10 flex items-center justify-center gap-2">
                AUTHENTICATE
                <svg
                    class="w-4 h-4 transition-transform group-hover:translate-x-1"
                    fill="none"
                    stroke="currentColor"
                    viewBox="0 0 24 24"
                    ><path
                        d="M13 7l5 5m0 0l-5 5m5-5H6"
                        stroke-width="3"
                        stroke-linecap="round"
                        stroke-linejoin="round"></path></svg
                >
            </span>
        </button>
    </div>
</div>

<div
    id="dashboardContainer"
    class="hidden max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-10 animate-in fade-in slide-in-from-bottom-4 duration-700"
>
    <!-- Premium Header -->
    <div
        class="flex flex-col md:flex-row md:items-end justify-between gap-6 mb-10"
    >
        <div>
            <div class="flex items-center gap-2 mb-2">
                <span class="w-2 h-2 rounded-full bg-neon-blue animate-pulse"
                ></span>
                <span
                    class="text-[10px] font-black text-neon-blue uppercase tracking-[0.3em]"
                    >System Live</span
                >
            </div>
            <h1 class="text-4xl font-black text-white tracking-tighter">
                Command <span
                    class="text-transparent bg-clip-text bg-gradient-to-r from-neon-blue to-neon-purple"
                    >Center</span
                >
            </h1>
        </div>

        <!-- Tab Navigation -->
        <div
            class="flex overflow-x-auto bg-slate-900/50 backdrop-blur-md p-1.5 rounded-2xl border border-white/5"
        >
            <button
                id="tabDashboard"
                class="px-6 py-2.5 rounded-xl text-xs font-black uppercase tracking-widest transition-all tab-btn bg-white text-black"
                data-target="panelDashboard">Overview</button
            >
            <button
                id="tabSettings"
                class="px-6 py-2.5 rounded-xl text-xs font-black uppercase tracking-widest transition-all tab-btn text-slate-500 hover:text-white"
                data-target="panelSettings">Config</button
            >
            <button
                id="tabHistory"
                class="px-6 py-2.5 rounded-xl text-xs font-black uppercase tracking-widest transition-all tab-btn text-slate-500 hover:text-white"
                data-target="panelHistory">Logs</button
            >
            <button
                id="tabApiKeys"
                class="px-6 py-2.5 rounded-xl text-xs font-black uppercase tracking-widest transition-all tab-btn text-slate-500 hover:text-white"
                data-target="panelApiKeys">API</button
            >
            <button
                id="tabDocs"
                class="px-6 py-2.5 rounded-xl text-xs font-black uppercase tracking-widest transition-all tab-btn text-slate-500 hover:text-white"
                data-target="panelDocs">Docs</button
            >
            <div class="w-px h-8 bg-white/5 mx-2 self-center"></div>
            <button
                id="logoutBtn"
                class="p-2.5 rounded-xl text-rose-500 hover:bg-rose-500/10 transition-all border border-transparent hover:border-rose-500/20"
                title="Sign Out"
            >
                <svg
                    class="w-5 h-5"
                    fill="none"
                    stroke="currentColor"
                    viewBox="0 0 24 24"
                    ><path
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        stroke-width="2.5"
                        d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1"
                    ></path></svg
                >
            </button>
        </div>
    </div>

    <!-- Main Content Panels -->
    <div class="relative">
        <!-- Dashboard Panel -->
        <div
            id="panelDashboard"
            class="space-y-8 tab-panel block animate-in fade-in duration-500"
        >
            <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
                <!-- KPI Cards -->
                <div class="relative group">
                    <div
                        class="absolute -inset-0.5 bg-gradient-to-r from-blue-500 to-cyan-500 rounded-3xl blur opacity-20 group-hover:opacity-40 transition duration-500"
                    >
                    </div>
                    <div
                        class="relative bg-slate-900 border border-white/5 p-8 rounded-3xl overflow-hidden"
                    >
                        <div class="absolute top-0 right-0 p-4 opacity-10">
                            <svg
                                class="w-12 h-12 text-white"
                                fill="none"
                                stroke="currentColor"
                                viewBox="0 0 24 24"
                                ><path
                                    d="M13 7h8m0 0v8m0-8l-8 8-4-4-6 6"
                                    stroke-width="2"
                                    stroke-linecap="round"
                                    stroke-linejoin="round"></path></svg
                            >
                        </div>
                        <p
                            class="text-slate-500 text-[10px] font-black uppercase tracking-[0.2em] mb-4"
                        >
                            Total Transactions
                        </p>
                        <p
                            id="statTotal"
                            class="text-5xl font-black text-white italic tracking-tighter"
                        >
                            0
                        </p>
                    </div>
                </div>

                <div class="relative group">
                    <div
                        class="absolute -inset-0.5 bg-gradient-to-r from-emerald-500 to-teal-500 rounded-3xl blur opacity-20 group-hover:opacity-40 transition duration-500"
                    >
                    </div>
                    <div
                        class="relative bg-slate-900 border border-white/5 p-8 rounded-3xl overflow-hidden"
                    >
                        <div class="absolute top-0 right-0 p-4 opacity-10">
                            <svg
                                class="w-12 h-12 text-white"
                                fill="none"
                                stroke="currentColor"
                                viewBox="0 0 24 24"
                                ><path
                                    d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"
                                    stroke-width="2"
                                    stroke-linecap="round"
                                    stroke-linejoin="round"></path></svg
                            >
                        </div>
                        <p
                            class="text-slate-500 text-[10px] font-black uppercase tracking-[0.2em] mb-4"
                        >
                            Integrity Rate
                        </p>
                        <p
                            id="statRate"
                            class="text-5xl font-black text-emerald-400 italic tracking-tighter"
                        >
                            0%
                        </p>
                    </div>
                </div>

                <div class="relative group sm:col-span-2 lg:col-span-1">
                    <div
                        class="absolute -inset-0.5 bg-gradient-to-r from-neon-blue to-neon-purple rounded-3xl blur opacity-20 group-hover:opacity-40 transition duration-500"
                    >
                    </div>
                    <div
                        class="relative bg-slate-900 border border-white/5 p-8 rounded-3xl overflow-hidden"
                    >
                        <div class="absolute top-0 right-0 p-4 opacity-10">
                            <svg
                                class="w-12 h-12 text-white"
                                fill="none"
                                stroke="currentColor"
                                viewBox="0 0 24 24"
                                ><path
                                    d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z"
                                    stroke-width="2"
                                    stroke-linecap="round"
                                    stroke-linejoin="round"></path></svg
                            >
                        </div>
                        <p
                            class="text-slate-500 text-[10px] font-black uppercase tracking-[0.2em] mb-4"
                        >
                            Gross Revenue
                        </p>
                        <p
                            id="statRevenue"
                            class="text-5xl font-black text-white italic tracking-tighter"
                        >
                            ₹ 0.00
                        </p>
                    </div>
                </div>
            </div>

            <div
                class="bg-slate-900/40 backdrop-blur-sm border border-white/5 rounded-[2.5rem] p-8 lg:p-10"
            >
                <div class="flex items-center justify-between mb-8">
                    <div>
                        <h3
                            class="text-xl font-black text-white tracking-tight"
                        >
                            Activity Stream
                        </h3>
                        <p class="text-slate-500 text-xs font-medium">
                            Real-time signal monitoring
                        </p>
                    </div>
                    <button
                        id="refreshStatsBtn"
                        class="flex items-center gap-2 bg-white/5 hover:bg-white/10 px-4 py-2 rounded-xl text-[10px] font-black text-white transition-all uppercase tracking-widest border border-white/5"
                    >
                        <svg
                            class="w-3 h-3"
                            fill="none"
                            stroke="currentColor"
                            viewBox="0 0 24 24"
                            ><path
                                stroke-linecap="round"
                                stroke-linejoin="round"
                                stroke-width="3"
                                d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15"
                            ></path></svg
                        >
                        Refresh Stream
                    </button>
                </div>
                <div
                    id="timelineList"
                    class="grid grid-cols-1 md:grid-cols-2 gap-4"
                >
                    <p
                        class="col-span-full text-slate-600 italic text-sm text-center py-20"
                    >
                        Synchronizing data stream...
                    </p>
                </div>
            </div>
        </div>

        <!-- Settings Panel -->
        <div
            id="panelSettings"
            class="hidden tab-panel space-y-8 animate-in fade-in duration-500"
        >
            <div
                class="bg-slate-900 rounded-[2.5rem] border border-white/5 p-10"
            >
                <h3
                    class="text-2xl font-black text-white tracking-tighter mb-8 italic"
                >
                    MERCHANT IDENTITY
                </h3>
                <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
                    <div class="space-y-2">
                        <label
                            class="text-slate-500 text-[10px] font-black uppercase tracking-widest pl-2"
                            >VPA Target ID</label
                        >
                        <input
                            type="text"
                            id="configPa"
                            class="w-full bg-slate-800/50 border border-white/5 p-4 rounded-2xl text-white font-mono focus:border-neon-blue outline-none transition-all placeholder:text-slate-700"
                            placeholder="merchant@bank"
                        />
                    </div>
                    <div class="space-y-2">
                        <label
                            class="text-slate-500 text-[10px] font-black uppercase tracking-widest pl-2"
                            >Alias Name</label
                        >
                        <input
                            type="text"
                            id="configPn"
                            class="w-full bg-slate-800/50 border border-white/5 p-4 rounded-2xl text-white font-bold focus:border-neon-blue outline-none transition-all"
                        />
                    </div>
                    <div class="space-y-2">
                        <label
                            class="text-slate-500 text-[10px] font-black uppercase tracking-widest pl-2"
                            >Meta Title</label
                        >
                        <input
                            type="text"
                            id="configTitle"
                            class="w-full bg-slate-800/50 border border-white/5 p-4 rounded-2xl text-white font-bold focus:border-neon-blue outline-none transition-all"
                        />
                    </div>
                    <div class="space-y-2">
                        <label
                            class="text-slate-500 text-[10px] font-black uppercase tracking-widest pl-2"
                            >Handoff URL</label
                        >
                        <input
                            type="text"
                            id="configRedirect"
                            class="w-full bg-slate-800/50 border border-white/5 p-4 rounded-2xl text-white font-mono focus:border-neon-blue outline-none transition-all"
                            placeholder="https://yourstore.com/success"
                        />
                    </div>
                </div>

                <div
                    class="grid grid-cols-1 md:grid-cols-2 gap-6 mt-10 pt-10 border-t border-white/5"
                >
                    <label
                        class="group relative flex items-center justify-between p-6 bg-slate-800/30 rounded-3xl border border-white/5 cursor-pointer hover:bg-slate-800/50 transition-all"
                    >
                        <div class="flex items-center gap-4">
                            <div
                                class="w-12 h-12 bg-neon-blue/10 rounded-2xl flex items-center justify-center text-neon-blue"
                            >
                                <svg
                                    class="w-6 h-6"
                                    fill="none"
                                    stroke="currentColor"
                                    viewBox="0 0 24 24"
                                    ><path
                                        d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"
                                        stroke-width="2"
                                        stroke-linecap="round"
                                        stroke-linejoin="round"></path></svg
                                >
                            </div>
                            <div>
                                <p
                                    class="text-white font-black text-sm uppercase tracking-tight"
                                >
                                    Hard-Lock Amount
                                </p>
                                <p
                                    class="text-slate-500 text-[10px] font-bold uppercase tracking-widest"
                                >
                                    Disable user manual input
                                </p>
                            </div>
                        </div>
                        <input
                            type="checkbox"
                            id="configLock"
                            class="w-6 h-6 rounded-lg accent-neon-blue"
                        />
                    </label>

                    <label
                        class="group relative flex items-center justify-between p-6 bg-rose-500/5 rounded-3xl border border-rose-500/10 cursor-pointer hover:bg-rose-500/10 transition-all"
                    >
                        <div class="flex items-center gap-4">
                            <div
                                class="w-12 h-12 bg-rose-500/10 rounded-2xl flex items-center justify-center text-rose-500"
                            >
                                <svg
                                    class="w-6 h-6"
                                    fill="none"
                                    stroke="currentColor"
                                    viewBox="0 0 24 24"
                                    ><path
                                        d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"
                                        stroke-width="2"
                                        stroke-linecap="round"
                                        stroke-linejoin="round"></path></svg
                                >
                            </div>
                            <div>
                                <p
                                    class="text-rose-400 font-black text-sm uppercase tracking-tight"
                                >
                                    Maintenace Vector
                                </p>
                                <p
                                    class="text-rose-500/50 text-[10px] font-bold uppercase tracking-widest"
                                >
                                    Global system pause
                                </p>
                            </div>
                        </div>
                        <input
                            type="checkbox"
                            id="configMaint"
                            class="w-6 h-6 rounded-lg accent-rose-500"
                        />
                    </label>
                </div>

                <div class="mt-10 flex justify-end">
                    <button
                        id="saveConfigBtn"
                        class="bg-white text-black font-black px-12 py-5 rounded-[1.5rem] hover:scale-105 active:scale-95 transition-all shadow-xl shadow-white/5 uppercase tracking-[0.2em] text-xs"
                        >Commit Changes</button
                    >
                </div>
            </div>
        </div>

        <!-- History Panel -->
        <div
            id="panelHistory"
            class="hidden tab-panel space-y-8 animate-in fade-in duration-500"
        >
            <div
                class="bg-slate-900 rounded-[2.5rem] border border-white/5 p-8 lg:p-10"
            >
                <div class="flex items-center justify-between mb-10">
                    <h3
                        class="text-2xl font-black text-white italic tracking-tighter uppercase"
                    >
                        Signal Logs
                    </h3>
                    <button
                        id="refreshHistoryBtn"
                        class="p-3 bg-white/5 hover:bg-white/10 rounded-2xl border border-white/5 transition-all text-white"
                    >
                        <svg
                            class="w-5 h-5"
                            fill="none"
                            stroke="currentColor"
                            viewBox="0 0 24 24"
                            ><path
                                stroke-linecap="round"
                                stroke-linejoin="round"
                                stroke-width="2"
                                d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15"
                            ></path></svg
                        >
                    </button>
                </div>
                <div id="historyList" class="space-y-4">
                    <p
                        class="text-slate-600 italic text-center py-20 uppercase tracking-widest text-xs"
                    >
                        No records in memory
                    </p>
                </div>
            </div>
        </div>

        <!-- API Keys Panel -->
        <div
            id="panelApiKeys"
            class="hidden tab-panel space-y-8 animate-in fade-in duration-500"
        >
            <div
                class="bg-slate-900 rounded-[2.5rem] border border-white/5 p-10"
            >
                <div
                    class="flex flex-col sm:flex-row sm:items-center justify-between gap-6 mb-10"
                >
                    <div>
                        <h3
                            class="text-2xl font-black text-white italic tracking-tighter uppercase"
                        >
                            API Authentication
                        </h3>
                        <p
                            class="text-slate-500 text-[10px] font-black uppercase tracking-widest mt-1"
                        >
                            Live Key & Secret Pairs
                        </p>
                    </div>
                    <button
                        id="genKeyBtn"
                        class="bg-neon-blue text-black font-black px-8 py-4 rounded-2xl hover:scale-105 active:scale-95 transition-all uppercase tracking-widest text-[10px]"
                        >Generate Key Pair</button
                    >
                </div>
                <div id="apiKeysList" class="grid grid-cols-1 gap-4">
                    <p
                        class="col-span-full text-slate-600 italic text-center py-20 uppercase tracking-widest text-xs font-bold"
                    >
                        No API keys generated yet
                    </p>
                </div>
            </div>
        </div>

        <!-- Docs Panel -->
        <div
            id="panelDocs"
            class="hidden tab-panel space-y-8 animate-in fade-in duration-500"
        >
            <div
                class="bg-slate-900 rounded-[2.5rem] border border-white/10 p-2 overflow-hidden"
            >
                <div class="p-8 border-b border-white/5">
                    <h3
                        class="text-2xl font-black text-white italic tracking-tighter uppercase"
                    >
                        Integration Protocol
                    </h3>
                </div>
                <div class="p-8">
                    <IntegrationDocs
                        baseUrl="/"
                        exampleLink="/?pa=test@upi&pn=Test%20Store&am=1.00&tn=Integration%20Test"
                    />
                </div>
            </div>
        </div>

        <!-- Key Generated Modal -->
        <div
            id="keyModal"
            class="fixed inset-0 z-[9999] hidden items-center justify-center bg-black/80 backdrop-blur-xl p-4"
        >
            <div
                class="bg-slate-900 border border-white/10 rounded-[2.5rem] p-8 md:p-10 max-w-lg w-full shadow-2xl shadow-neon-blue/10 animate-in fade-in zoom-in duration-500"
            >
                <div class="flex items-center gap-3 mb-6">
                    <div
                        class="w-12 h-12 bg-emerald-500/10 rounded-2xl flex items-center justify-center"
                    >
                        <svg
                            class="w-6 h-6 text-emerald-400"
                            fill="none"
                            stroke="currentColor"
                            viewBox="0 0 24 24"
                            ><path
                                stroke-linecap="round"
                                stroke-linejoin="round"
                                stroke-width="2"
                                d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"
                            ></path></svg
                        >
                    </div>
                    <div>
                        <h3
                            class="text-xl font-black text-white tracking-tight"
                        >
                            Key Pair Generated
                        </h3>
                        <p
                            class="text-[10px] font-black text-emerald-400 uppercase tracking-[0.2em]"
                        >
                            Save these credentials now
                        </p>
                    </div>
                </div>

                <div
                    class="bg-rose-500/5 border border-rose-500/20 rounded-2xl p-4 mb-6"
                >
                    <p
                        class="text-rose-400 text-xs font-bold flex items-center gap-2"
                    >
                        <svg
                            class="w-4 h-4 shrink-0"
                            fill="none"
                            stroke="currentColor"
                            viewBox="0 0 24 24"
                            ><path
                                stroke-linecap="round"
                                stroke-linejoin="round"
                                stroke-width="2"
                                d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"
                            ></path></svg
                        >
                        The secret will NOT be shown again. Copy it now!
                    </p>
                </div>

                <div class="space-y-4 mb-8">
                    <!-- App Name -->
                    <div>
                        <label
                            class="text-[10px] font-black uppercase tracking-[0.2em] text-slate-500 mb-1.5 block"
                            >Application Name</label
                        >
                        <div
                            class="bg-slate-800/50 border border-white/5 rounded-xl px-4 py-3"
                        >
                            <span
                                id="modalKeyName"
                                class="text-white font-bold text-sm"></span>
                        </div>
                    </div>
                    <!-- Live Key -->
                    <div>
                        <label
                            class="text-[10px] font-black uppercase tracking-[0.2em] text-neon-blue mb-1.5 block"
                            >Live Key (Public)</label
                        >
                        <div
                            class="flex items-center gap-2 bg-slate-800/50 border border-neon-blue/20 rounded-xl px-4 py-3"
                        >
                            <code
                                id="modalLiveKey"
                                class="text-emerald-400 font-mono text-xs flex-1 break-all"
                            ></code>
                            <button
                                id="copyLiveKey"
                                class="shrink-0 p-2 bg-neon-blue/10 hover:bg-neon-blue hover:text-black rounded-lg transition-all text-neon-blue"
                            >
                                <svg
                                    class="w-4 h-4"
                                    fill="none"
                                    stroke="currentColor"
                                    viewBox="0 0 24 24"
                                    ><path
                                        stroke-linecap="round"
                                        stroke-linejoin="round"
                                        stroke-width="2"
                                        d="M8 16H6a2 2 0 01-2-2V6a2 2 0 012-2h8a2 2 0 012 2v2m-6 12h8a2 2 0 002-2v-8a2 2 0 00-2-2h-8a2 2 0 00-2 2v8a2 2 0 002 2z"
                                    ></path></svg
                                >
                            </button>
                        </div>
                    </div>
                    <!-- Secret -->
                    <div>
                        <label
                            class="text-[10px] font-black uppercase tracking-[0.2em] text-neon-purple mb-1.5 block"
                            >Secret Key (Private)</label
                        >
                        <div
                            class="flex items-center gap-2 bg-slate-800/50 border border-neon-purple/20 rounded-xl px-4 py-3"
                        >
                            <code
                                id="modalSecret"
                                class="text-amber-400 font-mono text-xs flex-1 break-all"
                            ></code>
                            <button
                                id="copySecret"
                                class="shrink-0 p-2 bg-neon-purple/10 hover:bg-neon-purple hover:text-black rounded-lg transition-all text-neon-purple"
                            >
                                <svg
                                    class="w-4 h-4"
                                    fill="none"
                                    stroke="currentColor"
                                    viewBox="0 0 24 24"
                                    ><path
                                        stroke-linecap="round"
                                        stroke-linejoin="round"
                                        stroke-width="2"
                                        d="M8 16H6a2 2 0 01-2-2V6a2 2 0 012-2h8a2 2 0 012 2v2m-6 12h8a2 2 0 002-2v-8a2 2 0 00-2-2h-8a2 2 0 00-2 2v8a2 2 0 002 2z"
                                    ></path></svg
                                >
                            </button>
                        </div>
                    </div>
                </div>

                <button
                    id="closeKeyModal"
                    class="w-full bg-white text-black font-black py-4 rounded-2xl hover:scale-[1.02] active:scale-[0.98] transition-all uppercase tracking-[0.2em] text-xs"
                >
                    I've Saved My Credentials
                </button>
            </div>
        </div>
    </div>
</div>

<script>
    let sessionPin = "";

    const authContainer = document.getElementById(
        "authContainer",
    ) as HTMLElement;
    const dashboardContainer = document.getElementById(
        "dashboardContainer",
    ) as HTMLElement;
    const adminPinInput = document.getElementById(
        "adminPinInput",
    ) as HTMLInputElement;
    const unlockBtn = document.getElementById("unlockBtn") as HTMLButtonElement;
    const authErrorMsg = document.getElementById("authErrorMsg") as HTMLElement;

    const configPa = document.getElementById("configPa") as HTMLInputElement;
    const configPn = document.getElementById("configPn") as HTMLInputElement;
    const configTitle = document.getElementById(
        "configTitle",
    ) as HTMLInputElement;
    const configRedirect = document.getElementById(
        "configRedirect",
    ) as HTMLInputElement;
    const configLock = document.getElementById(
        "configLock",
    ) as HTMLInputElement;
    const configMaint = document.getElementById(
        "configMaint",
    ) as HTMLInputElement;
    const saveConfigBtn = document.getElementById(
        "saveConfigBtn",
    ) as HTMLButtonElement;

    const historyList = document.getElementById("historyList") as HTMLElement;
    const apiKeysList = document.getElementById("apiKeysList") as HTMLElement;
    const genKeyBtn = document.getElementById("genKeyBtn") as HTMLButtonElement;

    // Tab Logic
    const tabBtns = document.querySelectorAll(".tab-btn");
    const tabPanels = document.querySelectorAll(".tab-panel");

    tabBtns.forEach((btn) => {
        btn.addEventListener("click", () => {
            tabBtns.forEach((b) => {
                b.classList.remove("bg-white", "text-black");
                b.classList.add("text-slate-500", "hover:text-white");
            });
            btn.classList.add("bg-white", "text-black");
            btn.classList.remove("text-slate-500", "hover:text-white");

            tabPanels.forEach((p) => p.classList.add("hidden"));
            const target = btn.getAttribute("data-target");
            if (target) {
                const targetPanel = document.getElementById(target);
                if (targetPanel) targetPanel.classList.remove("hidden");
            }

            if (target === "panelDashboard") fetchStats();
            if (target === "panelSettings") fetchConfig();
            if (target === "panelHistory") fetchHistory();
            if (target === "panelApiKeys") fetchApiKeys();
        });
    });

    async function fetchStats() {
        if (!sessionPin) return;
        try {
            const res = await fetch("/api/stats", {
                headers: { "x-admin-pin": sessionPin },
            });
            const data = await res.json();

            const statTotal = document.getElementById("statTotal");
            if (statTotal) statTotal.innerText = data.total || "0";

            const rate =
                data.total > 0
                    ? ((data.successCount / data.total) * 100).toFixed(1)
                    : "0";
            const statRate = document.getElementById("statRate");
            if (statRate) statRate.innerText = rate + "%";

            const statRevenue = document.getElementById("statRevenue");
            if (statRevenue)
                statRevenue.innerText =
                    "₹ " + (data.totalAmount || 0).toFixed(2);

            const timelineList = document.getElementById("timelineList");
            if (timelineList && data.recent) {
                timelineList.innerHTML = data.recent
                    .map(
                        (p: any) => `
                    <div class="flex items-center justify-between bg-slate-800/20 p-5 rounded-[1.5rem] border border-white/5 hover:border-white/10 transition-all group">
                        <div class="flex items-center gap-4">
                            <div class="w-10 h-10 rounded-2xl flex items-center justify-center ${p.status === "SUCCESS" ? "bg-emerald-500/10 text-emerald-500" : "bg-slate-500/10 text-slate-500"}">
                                <span class="text-xs font-black">₹</span>
                            </div>
                            <div>
                                <p class="text-sm font-black text-white tracking-tight">₹ ${p.amount}</p>
                                <p class="text-[10px] text-slate-500 font-bold uppercase tracking-widest">${p.status}</p>
                            </div>
                        </div>
                        <span class="text-[10px] text-slate-600 font-black uppercase tracking-widest">${new Date(p.createdAt).toLocaleTimeString()}</span>
                    </div>
                `,
                    )
                    .join("");
                if (data.recent.length === 0) {
                    timelineList.innerHTML =
                        '<div class="col-span-full py-20 text-center"><p class="text-slate-600 italic text-xs uppercase tracking-[0.2em] font-bold">Quiet on the wire...</p></div>';
                }
            }
        } catch (e) {
            console.error(e);
        }
    }

    const savedPin = localStorage.getItem("admin_session_pin");
    if (savedPin) {
        sessionPin = savedPin;
        if (authContainer) authContainer.classList.add("hidden");
        if (dashboardContainer) dashboardContainer.classList.remove("hidden");
        fetchStats();
    }

    const doAuth = async () => {
        const pin = adminPinInput.value || (savedPin as string) || "";
        if (!pin) return;
        unlockBtn.innerText = "VERIFYING...";
        unlockBtn.disabled = true;

        try {
            const res = await fetch("/api/admin", {
                method: "POST",
                headers: { "Content-Type": "application/json" },
                body: JSON.stringify({ action: "verify", pin }),
            });
            const data = await res.json();
            if (data.success) {
                sessionPin = pin;
                localStorage.setItem("admin_session_pin", pin);
                if (authContainer) authContainer.classList.add("hidden");
                if (dashboardContainer)
                    dashboardContainer.classList.remove("hidden");
                fetchStats();
            } else {
                if (authErrorMsg) {
                    authErrorMsg.innerText = data.error || "ACCESS DENIED";
                    authErrorMsg.classList.remove("hidden");
                    localStorage.removeItem("admin_session_pin");
                }
            }
        } catch (e) {
            if (authErrorMsg) {
                authErrorMsg.innerText = "COMMAND LINK FAILED";
                authErrorMsg.classList.remove("hidden");
            }
        } finally {
            unlockBtn.innerHTML = `
                <span class="relative z-10 flex items-center justify-center gap-2">
                    AUTHENTICATE
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path d="M13 7l5 5m0 0l-5 5m5-5H6" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"/></svg>
                </span>
            `;
            unlockBtn.disabled = false;
        }
    };

    const doLogout = () => {
        sessionPin = "";
        localStorage.removeItem("admin_session_pin");
        if (dashboardContainer) dashboardContainer.classList.add("hidden");
        if (authContainer) authContainer.classList.remove("hidden");
    };

    document.getElementById("logoutBtn")?.addEventListener("click", doLogout);

    unlockBtn?.addEventListener("click", doAuth);
    adminPinInput?.addEventListener("keydown", (e) => {
        if (e.key === "Enter") doAuth();
    });

    async function fetchConfig() {
        if (!sessionPin) return;
        try {
            const res = await fetch("/api/config", {
                headers: { "x-admin-pin": sessionPin },
            });
            const data = await res.json();
            if (configPa) configPa.value = data.pa || "";
            if (configPn) configPn.value = data.pn || "";
            if (configTitle) configTitle.value = data.title || "";
            if (configRedirect) configRedirect.value = data.redirectUrl || "";
            if (configLock) configLock.checked = !!data.amountLocked;
            if (configMaint) configMaint.checked = !!data.maintenanceMode;
        } catch (e) {
            console.error(e);
        }
    }

    async function fetchHistory() {
        if (!sessionPin || !historyList) return;
        try {
            const res = await fetch("/api/payment", {
                headers: { "x-admin-pin": sessionPin },
            });
            const data = await res.json();
            historyList.innerHTML = data
                .map(
                    (item: any) => `
                <div class="bg-slate-800/40 p-6 rounded-[2rem] border border-white/5 flex flex-col md:flex-row md:items-center justify-between gap-4">
                    <div class="flex items-center gap-5">
                        <div class="w-14 h-14 rounded-2xl bg-slate-900 border border-white/5 flex items-center justify-center text-white">
                           <span class="font-black text-lg">₹</span>
                        </div>
                        <div>
                            <p class="font-black text-2xl text-white tracking-tighter italic">₹ ${item.amount}</p>
                            <p class="text-[10px] text-slate-500 font-bold uppercase tracking-widest mt-0.5">Reference ID: ${item.utr || "UNRESOLVED"}</p>
                        </div>
                    </div>
                    <div class="flex items-center gap-4">
                        <span class="text-[10px] text-slate-600 font-black uppercase tracking-widest">${new Date(item.createdAt).toLocaleString()}</span>
                        <span class="px-5 py-2 text-[10px] font-black uppercase tracking-widest rounded-xl ${item.status === "SUCCESS" ? "bg-emerald-500/10 text-emerald-400 border border-emerald-500/20" : "bg-rose-500/10 text-rose-400 border border-rose-500/20"}">
                            ${item.status}
                        </span>
                    </div>
                </div>
            `,
                )
                .join("");
            if (data.length === 0) {
                historyList.innerHTML =
                    '<p class="text-slate-600 italic text-center py-20 uppercase tracking-widest text-xs">No records in memory</p>';
            }
        } catch (e) {
            console.error(e);
        }
    }

    async function fetchApiKeys() {
        if (!sessionPin || !apiKeysList) return;
        try {
            (window as any).deleteKey = async (id: string) => {
                if (confirm("Permanently revoke this access key?")) {
                    await fetch("/api/apikey?id=" + id, {
                        method: "DELETE",
                        headers: { "x-admin-pin": sessionPin },
                    });
                    fetchApiKeys();
                }
            };
            const res = await fetch("/api/apikey", {
                headers: { "x-admin-pin": sessionPin },
            });
            const data = await res.json();
            const maskKey = (k: string) =>
                k.substring(0, 12) + "••••••••" + k.substring(k.length - 4);
            apiKeysList.innerHTML = (data.keys || [])
                .map(
                    (key: any) => `
                <div class="bg-slate-800/40 p-6 rounded-[2rem] border border-white/5 hover:border-white/10 transition-all group">
                    <div class="flex items-center justify-between mb-4">
                        <div class="flex items-center gap-4">
                            <div class="w-10 h-10 bg-white/5 rounded-xl flex items-center justify-center text-white/50 group-hover:text-neon-blue transition-colors">
                                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path d="M15 7a2 2 0 012 2m4 0a6 6 0 01-7.743 5.743L11 17H9v2H7v2H4a1 1 0 01-1-1v-2.586a1 1 0 01.293-.707l5.964-5.964A6 6 0 1121 9z" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
                            </div>
                            <div>
                                <p class="font-black text-white text-sm uppercase tracking-tight">${key.name}</p>
                                <p class="text-[10px] text-slate-500 font-mono mt-1">${maskKey(key.key)}</p>
                            </div>
                        </div>
                        <div class="flex items-center gap-3">
                            <span class="px-3 py-1 text-[9px] font-black uppercase tracking-widest rounded-lg ${key.active ? "bg-emerald-500/10 text-emerald-400 border border-emerald-500/20" : "bg-rose-500/10 text-rose-400 border border-rose-500/20"}">${key.active ? "Active" : "Revoked"}</span>
                            <button onclick="deleteKey('${key.id}')" class="text-rose-500 text-[10px] font-black uppercase tracking-widest hover:bg-rose-500/10 px-4 py-2 rounded-xl transition-all">Delete</button>
                        </div>
                    </div>
                    <div class="flex items-center justify-between text-[10px] text-slate-600 font-bold uppercase tracking-widest">
                        <span>Created: ${new Date(key.createdAt).toLocaleDateString()}</span>
                        <span class="italic">Secret: ••••••••••••</span>
                    </div>
                </div>
            `,
                )
                .join("");
            if ((data.keys || []).length === 0) {
                apiKeysList.innerHTML =
                    '<p class="col-span-full text-slate-600 italic text-center py-20 uppercase tracking-widest text-xs font-bold">No API keys generated yet</p>';
            }
        } catch (e) {
            console.error(e);
        }
    }

    saveConfigBtn?.addEventListener("click", async () => {
        if (!sessionPin) return;
        saveConfigBtn.innerText = "SAVING...";
        saveConfigBtn.disabled = true;
        try {
            const res = await fetch("/api/config", {
                method: "POST",
                headers: {
                    "Content-Type": "application/json",
                    "x-admin-pin": sessionPin,
                },
                body: JSON.stringify({
                    pa: configPa?.value,
                    pn: configPn?.value,
                    title: configTitle?.value,
                    redirectUrl: configRedirect?.value,
                    amountLocked: configLock?.checked,
                    maintenanceMode: configMaint?.checked,
                }),
            });
            if (res.ok) {
                alert("Protocol Updated Successfully");
            } else {
                alert("Commencing Save Error: " + res.statusText);
            }
        } catch (e) {
            alert("Failed to reach terminal.");
        } finally {
            saveConfigBtn.innerText = "COMMIT CHANGES";
            saveConfigBtn.disabled = false;
        }
    });

    // Key Modal Elements
    const keyModal = document.getElementById("keyModal") as HTMLElement;
    const modalLiveKey = document.getElementById("modalLiveKey") as HTMLElement;
    const modalSecret = document.getElementById("modalSecret") as HTMLElement;
    const modalKeyName = document.getElementById("modalKeyName") as HTMLElement;
    const closeKeyModal = document.getElementById(
        "closeKeyModal",
    ) as HTMLButtonElement;
    const copyLiveKey = document.getElementById(
        "copyLiveKey",
    ) as HTMLButtonElement;
    const copySecret = document.getElementById(
        "copySecret",
    ) as HTMLButtonElement;

    function showKeyModal(name: string, liveKey: string, secret: string) {
        if (modalKeyName) modalKeyName.textContent = name;
        if (modalLiveKey) modalLiveKey.textContent = liveKey;
        if (modalSecret) modalSecret.textContent = secret;
        if (keyModal) {
            keyModal.classList.remove("hidden");
            keyModal.classList.add("flex");
        }
    }

    closeKeyModal?.addEventListener("click", () => {
        if (keyModal) {
            keyModal.classList.add("hidden");
            keyModal.classList.remove("flex");
        }
    });

    copyLiveKey?.addEventListener("click", () => {
        const text = modalLiveKey?.textContent || "";
        navigator.clipboard.writeText(text);
        copyLiveKey.innerHTML =
            '<svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>';
        setTimeout(() => {
            copyLiveKey.innerHTML =
                '<svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 16H6a2 2 0 01-2-2V6a2 2 0 012-2h8a2 2 0 012 2v2m-6 12h8a2 2 0 002-2v-8a2 2 0 00-2-2h-8a2 2 0 00-2 2v8a2 2 0 002 2z"></path></svg>';
        }, 2000);
    });

    copySecret?.addEventListener("click", () => {
        const text = modalSecret?.textContent || "";
        navigator.clipboard.writeText(text);
        copySecret.innerHTML =
            '<svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>';
        setTimeout(() => {
            copySecret.innerHTML =
                '<svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 16H6a2 2 0 01-2-2V6a2 2 0 012-2h8a2 2 0 012 2v2m-6 12h8a2 2 0 002-2v-8a2 2 0 00-2-2h-8a2 2 0 00-2 2v8a2 2 0 002 2z"></path></svg>';
        }, 2000);
    });

    genKeyBtn?.addEventListener("click", async () => {
        const name = prompt("Enter application name for this key pair:");
        if (!name) return;
        genKeyBtn.textContent = "GENERATING...";
        genKeyBtn.disabled = true;
        try {
            const res = await fetch("/api/apikey", {
                method: "POST",
                headers: {
                    "Content-Type": "application/json",
                    "x-admin-pin": sessionPin,
                },
                body: JSON.stringify({ name }),
            });
            const data = await res.json();
            if (data.success) {
                showKeyModal(data.name, data.liveKey, data.secret);
                fetchApiKeys();
            } else {
                alert(
                    "Failed to generate key: " +
                        (data.error || "Unknown error"),
                );
            }
        } catch (e) {
            alert("Key generation failed.");
        } finally {
            genKeyBtn.textContent = "GENERATE KEY PAIR";
            genKeyBtn.disabled = false;
        }
    });

    document
        .getElementById("refreshStatsBtn")
        ?.addEventListener("click", fetchStats);
    document
        .getElementById("refreshHistoryBtn")
        ?.addEventListener("click", fetchHistory);

    declare global {
        interface Window {
            deleteKey: (id: string) => void;
        }
    }
</script>
