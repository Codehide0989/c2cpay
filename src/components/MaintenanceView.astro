---
// MaintenanceView.astro
export interface Props {
    message?: string;
    endTime?: number | null;
}

const { message, endTime } = Astro.props;
---

<div
    class="flex flex-col items-center justify-center min-h-[80vh] w-full px-6 animate-in fade-in duration-1000"
>
    <div class="relative w-full max-w-lg">
        <!-- Orbital Rings - Background Decor -->
        <div
            class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[150%] aspect-square border border-white/5 rounded-full pointer-events-none opacity-20"
        >
        </div>
        <div
            class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[120%] aspect-square border border-white/5 rounded-full pointer-events-none opacity-10 animate-spin-slow"
        >
        </div>

        <div
            class="relative bg-slate-900/40 backdrop-blur-3xl border border-white/10 rounded-[3rem] p-10 md:p-16 shadow-[0_0_100px_-20px_rgba(0,243,255,0.1)] overflow-hidden"
        >
            <!-- Interior Shimmer -->
            <div
                class="absolute inset-0 bg-gradient-to-tr from-neon-blue/5 via-transparent to-neon-purple/5 opacity-50"
            >
            </div>

            <div class="relative z-10 flex flex-col items-center">
                <!-- Terminal Icon Hub -->
                <div class="relative mb-12">
                    <div
                        class="absolute inset-0 bg-neon-blue rounded-full blur-2xl opacity-20 animate-pulse"
                    >
                    </div>
                    <div
                        class="relative w-28 h-28 bg-slate-950 border border-white/10 rounded-3xl flex items-center justify-center shadow-inner group overflow-hidden"
                    >
                        <div
                            class="absolute inset-0 bg-gradient-to-br from-white/10 to-transparent opacity-0 group-hover:opacity-100 transition-opacity"
                        >
                        </div>
                        <svg
                            class="w-14 h-14 text-neon-blue group-hover:scale-110 transition-transform duration-700"
                            fill="none"
                            stroke="currentColor"
                            viewBox="0 0 24 24"
                            ><path
                                stroke-linecap="round"
                                stroke-linejoin="round"
                                stroke-width="2"
                                d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm1 15h-2v-2h2v2zm0-4h-2V7h2v6z"
                            ></path></svg
                        >
                        <div class="absolute top-2 right-2 flex gap-1">
                            <div
                                class="w-1.5 h-1.5 rounded-full bg-rose-500 animate-pulse"
                            >
                            </div>
                            <div
                                class="w-1.5 h-1.5 rounded-full bg-amber-500 animate-pulse"
                                style="animation-delay: 0.2s"
                            >
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Text Architecture -->
                <div class="text-center space-y-6 mb-12">
                    <div
                        class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-neon-blue/10 border border-neon-blue/20 text-[10px] font-black uppercase tracking-[0.3em] text-neon-blue"
                    >
                        <svg
                            class="w-3 h-3"
                            fill="none"
                            stroke="currentColor"
                            viewBox="0 0 24 24"
                            ><path
                                stroke-linecap="round"
                                stroke-linejoin="round"
                                stroke-width="2"
                                d="M13 10V3L4 14h7v7l9-11h-7z"></path></svg
                        >
                        System Calibrating
                    </div>
                    <h2
                        class="text-4xl md:text-6xl font-black text-white tracking-tighter leading-none italic"
                    >
                        MAINTENANCE
                    </h2>
                    <p
                        class="text-slate-400 text-sm md:text-lg font-medium leading-relaxed max-w-sm mx-auto opacity-70"
                    >
                        {
                            message ||
                                "Optimizing infrastructure for high-velocity transaction processing."
                        }
                    </p>
                </div>

                <!-- Metric Components -->
                <div class="grid grid-cols-2 gap-4 w-full mb-10">
                    <div
                        class="p-6 bg-white/[0.02] border border-white/5 rounded-3xl flex flex-col items-center gap-3 group hover:bg-white/5 transition-all"
                    >
                        <svg
                            class="w-6 h-6 text-neon-purple animate-pulse"
                            fill="none"
                            stroke="currentColor"
                            viewBox="0 0 24 24"
                            ><path
                                stroke-linecap="round"
                                stroke-linejoin="round"
                                stroke-width="2"
                                d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"
                            ></path></svg
                        >
                        <div class="text-center">
                            <span
                                class="block text-[10px] font-black uppercase tracking-widest text-slate-500 mb-1"
                                >Eta</span
                            >
                            <span
                                id="maintenanceTimer"
                                class="text-xl font-bold text-white font-mono tracking-wider"
                                data-endtime={endTime || ""}
                                >{endTime ? "..." : "10:00"}</span
                            >
                        </div>
                    </div>
                    <div
                        class="p-6 bg-white/[0.02] border border-white/5 rounded-3xl flex flex-col items-center gap-3 group hover:bg-white/5 transition-all"
                    >
                        <svg
                            class="w-6 h-6 text-neon-blue animate-spin-slow"
                            fill="none"
                            stroke="currentColor"
                            viewBox="0 0 24 24"
                            ><path
                                stroke-linecap="round"
                                stroke-linejoin="round"
                                stroke-width="2"
                                d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15"
                            ></path></svg
                        >
                        <div class="text-center">
                            <span
                                class="block text-[10px] font-black uppercase tracking-widest text-slate-500 mb-1"
                                >State</span
                            >
                            <span
                                class="text-xl font-bold text-white uppercase tracking-tighter italic"
                                >Syncing</span
                            >
                        </div>
                    </div>
                </div>

                <!-- Protocol Activation -->
                <div class="w-full space-y-6">
                    <button
                        onclick="window.location.reload()"
                        class="w-full py-5 bg-white text-black text-sm font-black rounded-2xl hover:bg-neon-blue hover:text-white transition-all shadow-xl active:scale-95 flex items-center justify-center gap-4 group uppercase tracking-[0.25em]"
                    >
                        <svg class="w-5 h-5 fill-current" viewBox="0 0 24 24"
                            ><path d="M13 10V3L4 14h7v7l9-11h-7z"></path></svg
                        >
                        Re-sync Handshake
                    </button>

                    <a
                        href="/admin"
                        class="group w-full flex items-center justify-center gap-2 text-[10px] text-slate-600 hover:text-white transition-all uppercase tracking-[0.4em] font-black pt-2"
                    >
                        <svg
                            class="w-3 h-3 opacity-0 group-hover:opacity-100 transition-opacity"
                            fill="none"
                            stroke="currentColor"
                            viewBox="0 0 24 24"
                            ><path
                                stroke-linecap="round"
                                stroke-linejoin="round"
                                stroke-width="2"
                                d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"
                            ></path></svg
                        >
                        Stealth Entry
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>

<script>
    const timerEl = document.getElementById("maintenanceTimer");
    const endTimeAttr = timerEl?.getAttribute("data-endtime");
    if (endTimeAttr) {
        const endTime = parseInt(endTimeAttr);
        const updateTimer = () => {
            const diff = endTime - Date.now();
            if (diff <= 0) {
                if (timerEl) timerEl.innerText = "00:00";
                return;
            }
            const mins = Math.floor(diff / 60000)
                .toString()
                .padStart(2, "0");
            const secs = Math.floor((diff % 60000) / 1000)
                .toString()
                .padStart(2, "0");
            if (timerEl) timerEl.innerText = `${mins}:${secs}`;
        };
        setInterval(updateTimer, 1000);
        updateTimer();
    }
</script>
