---
// BaseBoard.astro
---

<div
    class="min-h-screen w-full bg-[#020617] text-white p-3 sm:p-4 md:p-6 font-sans selection:bg-neon-blue selection:text-black lg:pt-28"
>
    <div class="fixed inset-0 pointer-events-none z-[-1] overflow-hidden">
        <div
            class="absolute inset-0 bg-[url('https://www.transparenttextures.com/patterns/carbon-fibre.png')] opacity-[0.03]"
        >
        </div>
        <div
            class="absolute top-[-20%] left-[-10%] w-[60%] h-[60%] bg-neon-blue/10 rounded-full blur-[80px] sm:blur-[120px] animate-pulse"
        >
        </div>
        <div
            class="absolute bottom-[-20%] right-[-10%] w-[60%] h-[60%] bg-neon-purple/5 rounded-full blur-[80px] sm:blur-[120px] animate-pulse"
            style="animation-delay: 2s;"
        >
        </div>
    </div>

    <div
        class="max-w-7xl mx-auto space-y-4 sm:space-y-6 lg:space-y-8 animate-in fade-in slide-in-from-bottom-4 duration-1000"
    >
        <!-- Header -->
        <div
            class="flex flex-col sm:flex-row sm:items-end justify-between gap-3 sm:gap-4 pb-3 sm:pb-4 border-b border-slate-800/50"
        >
            <div class="flex items-center gap-3 sm:gap-4">
                <div class="relative group">
                    <div
                        class="absolute -inset-1 bg-gradient-to-r from-neon-blue to-neon-purple rounded-xl sm:rounded-2xl blur opacity-25 group-hover:opacity-50 transition duration-1000 group-hover:duration-200"
                    >
                    </div>
                    <div
                        class="relative w-10 h-10 sm:w-12 sm:h-12 bg-slate-900 border border-slate-800 rounded-xl sm:rounded-2xl flex items-center justify-center"
                    >
                        <svg
                            class="w-6 h-6 text-neon-blue animate-pulse"
                            fill="none"
                            stroke="currentColor"
                            viewBox="0 0 24 24"
                            ><path
                                stroke-linecap="round"
                                stroke-linejoin="round"
                                stroke-width="2"
                                d="M4 7v10c0 2.21 3.582 4 8 4s8-1.79 8-4V7M4 7c0 2.21 3.582 4 8 4s8-1.79 8-4M4 7c0-2.21 3.582-4 8-4s8 1.79 8 4m0 5c0 2.21-3.582 4-8 4s-8-1.79-8-4"
                            ></path></svg
                        >
                    </div>
                </div>
                <div>
                    <h1
                        class="text-xl md:text-3xl font-black tracking-tighter text-white uppercase"
                    >
                        NODE <span
                            class="bg-clip-text text-transparent bg-gradient-to-r from-neon-blue to-neon-purple"
                            >BASE</span
                        >
                    </h1>
                </div>
            </div>

            <div class="flex items-center gap-3 sm:gap-4">
                <div class="text-right hidden sm:block">
                    <p
                        class="text-[9px] font-black text-slate-600 uppercase tracking-widest mb-1"
                    >
                        Pulse Cycle: <span id="countdownText">10</span>s
                    </p>
                    <div
                        class="w-24 h-1 bg-slate-800 rounded-full overflow-hidden"
                    >
                        <div
                            id="countdownBar"
                            class="h-full bg-neon-blue transition-all duration-1000 ease-linear shadow-[0_0_8px_rgba(0,229,255,0.5)]"
                            style="width: 100%"
                        >
                        </div>
                    </div>
                </div>
                <button
                    id="syncBtn"
                    class="group relative bg-slate-900 hover:bg-slate-800 border border-slate-800 px-4 py-2.5 rounded-xl flex items-center gap-2 transition-all active:scale-95 shadow-xl"
                >
                    <svg
                        class="w-3.5 h-3.5 text-neon-blue group-hover:rotate-180 transition-transform duration-500"
                        fill="none"
                        viewBox="0 0 24 24"
                        stroke="currentColor"
                        ><path
                            stroke-linecap="round"
                            stroke-linejoin="round"
                            stroke-width="2"
                            d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15"
                        ></path></svg
                    >
                    <span
                        class="text-[10px] font-black uppercase tracking-widest text-white"
                        >Sync</span
                    >
                </button>
            </div>
        </div>

        <div class="grid grid-cols-1 lg:grid-cols-12 gap-6">
            <!-- Hero Status Card -->
            <div
                class="lg:col-span-8 bg-slate-900/60 border border-slate-800/80 rounded-3xl p-6 lg:p-8 relative overflow-hidden group shadow-2xl backdrop-blur-md"
            >
                <div
                    class="absolute top-0 right-0 p-12 opacity-[0.02] group-hover:opacity-[0.05] transition-opacity duration-1000 rotate-12"
                >
                    <svg
                        class="w-64 h-64"
                        fill="none"
                        stroke="currentColor"
                        viewBox="0 0 24 24"
                        ><path
                            stroke-linecap="round"
                            stroke-linejoin="round"
                            stroke-width="2"
                            d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm0 0v20M2 12h20M4.15 6h15.7M4.15 18h15.7"
                        ></path></svg
                    >
                </div>

                <div class="relative z-10 flex flex-col h-full justify-between">
                    <div class="space-y-6">
                        <div
                            id="statusBadge"
                            class="inline-flex items-center gap-3 px-4 py-1.5 rounded-full text-[10px] font-black uppercase tracking-[0.2em] border bg-emerald-500/10 border-emerald-500/20 text-emerald-400 shadow-[0_0_15px_rgba(16,185,129,0.1)]"
                        >
                            <div
                                class="w-2 h-2 rounded-full bg-emerald-500"
                                id="statusDot"
                            >
                            </div>
                            <span id="statusText"
                                >Scanning Infrastructure...</span
                            >
                        </div>

                        <div class="space-y-1">
                            <h2
                                id="mainStatusHeader"
                                class="text-4xl lg:text-6xl font-black text-white tracking-tighter leading-none"
                            >
                                SYSTEM ONLINE
                            </h2>
                            <p
                                id="mainStatusSub"
                                class="text-slate-400 max-w-xl text-[10px] md:text-sm font-bold uppercase tracking-widest opacity-70"
                            >
                                "Database Layer Node | Integrity: Optimal"
                            </p>
                        </div>
                    </div>

                    <div class="mt-8 grid grid-cols-2 sm:grid-cols-4 gap-3">
                        <div
                            class="bg-black/30 rounded-xl p-3 border border-white/5 transition-colors"
                        >
                            <span
                                class="text-[9px] text-slate-500 uppercase font-black tracking-widest"
                                >Latency</span
                            >
                            <span
                                id="statLatency"
                                class="block text-sm lg:text-base font-bold text-neon-blue mt-1"
                                >0ms</span
                            >
                        </div>
                        <div
                            class="bg-black/30 rounded-xl p-3 border border-white/5 transition-colors"
                        >
                            <span
                                class="text-[9px] text-slate-500 uppercase font-black tracking-widest"
                                >Layer</span
                            >
                            <span
                                class="block text-sm lg:text-base font-bold text-white mt-1"
                                >HTTP/3</span
                            >
                        </div>
                        <div
                            class="bg-black/30 rounded-xl p-3 border border-white/5 transition-colors"
                        >
                            <span
                                class="text-[9px] text-slate-500 uppercase font-black tracking-widest"
                                >Cluster</span
                            >
                            <span
                                class="block text-sm lg:text-base font-bold text-white mt-1"
                                >Active</span
                            >
                        </div>
                        <div
                            class="bg-black/30 rounded-xl p-3 border border-white/5 transition-colors"
                        >
                            <span
                                class="text-[9px] text-slate-500 uppercase font-black tracking-widest"
                                >Node</span
                            >
                            <span
                                id="statNode"
                                class="block text-sm lg:text-base font-bold text-emerald-400 mt-1"
                                >LOCAL</span
                            >
                        </div>
                    </div>
                </div>
            </div>

            <!-- Side Cards -->
            <div
                class="lg:col-span-4 grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-1 gap-3"
            >
                <div
                    class="bg-slate-900/40 border border-slate-800/80 p-4 lg:p-5 rounded-2xl backdrop-blur-xl relative shadow-lg shadow-black/20"
                >
                    <h4
                        class="text-[10px] font-black text-slate-500 uppercase tracking-widest mb-1"
                    >
                        Databases
                    </h4>
                    <p
                        id="dbStatus"
                        class="text-lg lg:text-xl font-bold tracking-tight text-white"
                    >
                        Active
                    </p>
                </div>
                <div
                    class="col-span-2 sm:col-span-3 lg:col-span-1 bg-gradient-to-br from-neon-blue/10 to-neon-purple/10 border border-neon-blue/20 p-4 lg:p-5 rounded-2xl shadow-xl backdrop-blur-md overflow-hidden"
                >
                    <h4
                        class="text-[10px] font-black text-neon-blue uppercase tracking-widest mb-1"
                    >
                        Health Score
                    </h4>
                    <div
                        id="healthScore"
                        class="text-2xl font-black text-white mb-2"
                    >
                        100%
                    </div>
                    <p
                        class="text-[9px] text-slate-500 font-bold uppercase leading-relaxed"
                    >
                        Neon PostgreSQL Active NODE.
                    </p>
                </div>
            </div>
        </div>
    </div>
</div>

<script>
    let countdown = 10;
    const syncBtn = document.getElementById("syncBtn");
    const statusText = document.getElementById("statusText");
    const mainStatusHeader = document.getElementById("mainStatusHeader");
    const mainStatusSub = document.getElementById("mainStatusSub");
    const statLatency = document.getElementById("statLatency");
    const dbStatus = document.getElementById("dbStatus");
    const healthScore = document.getElementById("healthScore");
    const statusBadge = document.getElementById("statusBadge");
    const statusDot = document.getElementById("statusDot");
    const countdownText = document.getElementById("countdownText");
    const countdownBar = document.getElementById("countdownBar");

    async function fetchStatus() {
        try {
            const start = Date.now();
            const res = await fetch("/api/status");
            const data = await res.json();
            const latency = Date.now() - start;

            if (statLatency) statLatency.innerText = `${latency}ms`;

            const isConnected =
                data.isConnected ||
                data.dbConnection?.currentState === "CONNECTED";

            if (isConnected) {
                if (statusText) statusText.innerText = "Healthy";
                if (mainStatusHeader)
                    mainStatusHeader.innerText = "SYSTEM ONLINE";
                if (mainStatusSub)
                    mainStatusSub.innerText = `"Database Layer Node | Integrity: Optimal"`;
                if (dbStatus) dbStatus.innerText = "Active";
                if (healthScore) healthScore.innerText = "100%";

                statusBadge?.classList.remove(
                    "bg-rose-500/10",
                    "border-rose-500/20",
                    "text-rose-400",
                );
                statusBadge?.classList.add(
                    "bg-emerald-500/10",
                    "border-emerald-500/20",
                    "text-emerald-400",
                );
                statusDot?.classList.remove("bg-rose-500");
                statusDot?.classList.add("bg-emerald-500");
            } else {
                if (statusText) statusText.innerText = "Offline";
                if (mainStatusHeader)
                    mainStatusHeader.innerText = "SYSTEM OFFLINE";
                if (mainStatusSub)
                    mainStatusSub.innerText = `"Database Layer Node | Integrity: Compromised"`;
                if (dbStatus) dbStatus.innerText = "Offline";
                if (healthScore) healthScore.innerText = "0%";

                statusBadge?.classList.add(
                    "bg-rose-500/10",
                    "border-rose-500/20",
                    "text-rose-400",
                );
                statusBadge?.classList.remove(
                    "bg-emerald-500/10",
                    "border-emerald-500/20",
                    "text-emerald-400",
                );
                statusDot?.classList.add("bg-rose-500");
                statusDot?.classList.remove("bg-emerald-500");
            }
        } catch (e) {
            console.error("Status check failed", e);
            if (statusText) statusText.innerText = "Offline";
            if (mainStatusHeader) mainStatusHeader.innerText = "SYSTEM OFFLINE";
            if (dbStatus) dbStatus.innerText = "Offline";
            if (healthScore) healthScore.innerText = "0%";
            statusBadge?.classList.add(
                "bg-rose-500/10",
                "border-rose-500/20",
                "text-rose-400",
            );
            statusBadge?.classList.remove(
                "bg-emerald-500/10",
                "border-emerald-500/20",
                "text-emerald-400",
            );
            statusDot?.classList.add("bg-rose-500");
            statusDot?.classList.remove("bg-emerald-500");
        }
        countdown = 10;
    }

    syncBtn?.addEventListener("click", fetchStatus);

    setInterval(fetchStatus, 10000);
    setInterval(() => {
        countdown = countdown > 0 ? countdown - 1 : 10;
        if (countdownText) countdownText.innerText = countdown.toString();
        if (countdownBar)
            countdownBar.style.width = `${(countdown / 10) * 100}%`;
    }, 1000);

    fetchStatus();
</script>
