---
// MobileApps.astro
---

<div
    class="w-full grid grid-cols-2 gap-3 mt-6 lg:hidden"
    id="mobileAppsContainer"
>
    <div class="col-span-2 text-center mb-2">
        <p
            class="text-[10px] text-slate-500 uppercase tracking-[0.3em] font-black"
        >
            Mobile Carrier Select
        </p>
    </div>

    <a
        href="#"
        id="gpayLink"
        class="relative overflow-hidden group flex items-center justify-center gap-2.5 p-3.5 rounded-2xl font-bold text-xs transition-all duration-300 transform active:scale-95 bg-slate-900/50 backdrop-blur-md border border-blue-500/30 text-blue-400 shadow-lg shadow-blue-500/20 hover:shadow-xl"
    >
        <div
            class="absolute inset-0 bg-gradient-to-br from-[#4285F4]/20 to-transparent opacity-50"
        >
        </div>
        <div
            class="absolute inset-0 bg-white/5 translate-x-[-100%] group-hover:translate-x-[100%] transition-transform duration-700 skew-x-12"
        >
        </div>
        <div class="relative z-10 flex items-center gap-2">
            <div class="p-1 rounded-lg bg-white/5">
                <svg
                    class="w-4 h-4"
                    fill="none"
                    stroke="currentColor"
                    viewBox="0 0 24 24"
                    ><path
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        d="M13 10V3L4 14h7v7l9-11h-7z"></path></svg>
            </div>
            <span class="tracking-tight uppercase">Google Pay</span>
        </div>
    </a>

    <a
        href="#"
        id="phonepeLink"
        class="relative overflow-hidden group flex items-center justify-center gap-2.5 p-3.5 rounded-2xl font-bold text-xs transition-all duration-300 transform active:scale-95 bg-slate-900/50 backdrop-blur-md border border-purple-500/30 text-purple-400 shadow-lg shadow-purple-500/20 hover:shadow-xl"
    >
        <div
            class="absolute inset-0 bg-gradient-to-br from-[#5f259f]/20 to-transparent opacity-50"
        >
        </div>
        <div
            class="absolute inset-0 bg-white/5 translate-x-[-100%] group-hover:translate-x-[100%] transition-transform duration-700 skew-x-12"
        >
        </div>
        <div class="relative z-10 flex items-center gap-2">
            <div class="p-1 rounded-lg bg-white/5">
                <svg
                    class="w-4 h-4"
                    fill="none"
                    stroke="currentColor"
                    viewBox="0 0 24 24"
                    ><path
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        d="M12 18h.01M8 21h8a2 2 0 002-2V5a2 2 0 00-2-2H8a2 2 0 00-2 2v14a2 2 0 002 2z"
                    ></path></svg>
            </div>
            <span class="tracking-tight uppercase">PhonePe</span>
        </div>
    </a>

    <a
        href="#"
        id="paytmLink"
        class="relative overflow-hidden group flex items-center justify-center gap-2.5 p-3.5 rounded-2xl font-bold text-xs transition-all duration-300 transform active:scale-95 bg-slate-900/50 backdrop-blur-md border border-sky-500/30 text-sky-400 shadow-lg shadow-sky-500/20 hover:shadow-xl"
    >
        <div
            class="absolute inset-0 bg-gradient-to-br from-[#00baf2]/20 to-transparent opacity-50"
        >
        </div>
        <div
            class="absolute inset-0 bg-white/5 translate-x-[-100%] group-hover:translate-x-[100%] transition-transform duration-700 skew-x-12"
        >
        </div>
        <div class="relative z-10 flex items-center gap-2">
            <div class="p-1 rounded-lg bg-white/5">
                <svg
                    class="w-4 h-4"
                    fill="none"
                    stroke="currentColor"
                    viewBox="0 0 24 24"
                    ><path
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        d="M3 10h18M7 15h1m4 0h1m-7 4h12a3 3 0 003-3V8a3 3 0 00-3-3H6a3 3 0 00-3 3v8a3 3 0 003 3z"
                    ></path></svg>
            </div>
            <span class="tracking-tight uppercase">Paytm</span>
        </div>
    </a>

    <a
        href="#"
        id="genericLink"
        class="relative overflow-hidden group flex items-center justify-center gap-2.5 p-3.5 rounded-2xl font-bold text-xs transition-all duration-300 transform active:scale-95 bg-slate-900/50 backdrop-blur-md border border-rose-500/30 text-rose-400 shadow-lg shadow-rose-500/20 hover:shadow-xl"
    >
        <div
            class="absolute inset-0 bg-gradient-to-br from-[#e91e63]/20 to-transparent opacity-50"
        >
        </div>
        <div
            class="absolute inset-0 bg-white/5 translate-x-[-100%] group-hover:translate-x-[100%] transition-transform duration-700 skew-x-12"
        >
        </div>
        <div class="relative z-10 flex items-center gap-2">
            <div class="p-1 rounded-lg bg-white/5">
                <svg
                    class="w-4 h-4"
                    fill="none"
                    stroke="currentColor"
                    viewBox="0 0 24 24"
                    ><path
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        d="M3 10h18M3 14h18m-9-4v8m-7 0h14a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v8a2 2 0 002 2z"
                    ></path></svg>
            </div>
            <span class="tracking-tight uppercase">Generic App</span>
        </div>
    </a>
</div>

<script>
    window.addEventListener("updateUpiLink", (e: any) => {
        const upiLink = e.detail;
        const gpay = document.getElementById("gpayLink") as HTMLAnchorElement;
        const phonepe = document.getElementById(
            "phonepeLink",
        ) as HTMLAnchorElement;
        const paytm = document.getElementById("paytmLink") as HTMLAnchorElement;
        const generic = document.getElementById(
            "genericLink",
        ) as HTMLAnchorElement;

        if (gpay) gpay.href = upiLink.replace("upi://", "tez://");
        if (phonepe) phonepe.href = upiLink.replace("upi://", "phonepe://");
        if (paytm) paytm.href = upiLink.replace("upi://", "paytmmp://");
        if (generic) generic.href = upiLink;
    });
</script>
