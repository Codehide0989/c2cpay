---
// MobileApps.astro
---

<div class="w-full grid grid-cols-2 gap-3 mt-6" id="mobileAppsContainer">
    <div class="col-span-2 text-center mb-2" id="selectUpiAppTitle">
        <p
            class="text-[10px] text-slate-500 uppercase tracking-[0.3em] font-black"
        >
            Select UPI App
        </p>
    </div>

    <a
        href="#"
        id="gpayLink"
        class="upi-button relative overflow-hidden group flex flex-col items-center justify-center gap-2 p-3.5 rounded-2xl font-bold text-[14px] transition-all duration-300 transform active:scale-95 bg-slate-800/50 backdrop-blur-md border border-white/10 text-white hover:border-blue-500/50 hover:shadow-[0_0_15px_rgba(59,130,246,0.3)]"
    >
        <div
            class="p-2 rounded-xl bg-blue-500/10 text-blue-400 group-hover:scale-110 transition-transform"
        >
            <svg
                class="w-5 h-5"
                fill="none"
                stroke="currentColor"
                viewBox="0 0 24 24"
            >
                <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    d="M13 10V3L4 14h7v7l9-11h-7z"></path>
            </svg>
        </div>
        <span class="tracking-tight uppercase">G-Pay</span>
    </a>

    <a
        href="#"
        id="phonepeLink"
        class="upi-button relative overflow-hidden group flex flex-col items-center justify-center gap-2 p-3.5 rounded-2xl font-bold text-[14px] transition-all duration-300 transform active:scale-95 bg-slate-800/50 backdrop-blur-md border border-white/10 text-white hover:border-purple-500/50 hover:shadow-[0_0_15px_rgba(168,85,247,0.3)]"
    >
        <div
            class="p-2 rounded-xl bg-purple-500/10 text-purple-400 group-hover:scale-110 transition-transform"
        >
            <svg
                class="w-5 h-5"
                fill="none"
                stroke="currentColor"
                viewBox="0 0 24 24"
            >
                <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    d="M12 18h.01M8 21h8a2 2 0 002-2V5a2 2 0 00-2-2H8a2 2 0 00-2 2v14a2 2 0 002 2z"
                ></path>
            </svg>
        </div>
        <span class="tracking-tight uppercase">PhonePe</span>
    </a>

    <a
        href="#"
        id="paytmLink"
        class="upi-button relative overflow-hidden group flex flex-col items-center justify-center gap-2 p-3.5 rounded-2xl font-bold text-[14px] transition-all duration-300 transform active:scale-95 bg-slate-800/50 backdrop-blur-md border border-white/10 text-white hover:border-sky-500/50 hover:shadow-[0_0_15px_rgba(14,165,233,0.3)]"
    >
        <div
            class="p-2 rounded-xl bg-sky-500/10 text-sky-400 group-hover:scale-110 transition-transform"
        >
            <svg
                class="w-5 h-5"
                fill="none"
                stroke="currentColor"
                viewBox="0 0 24 24"
            >
                <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    d="M3 10h18M7 15h1m4 0h1m-7 4h12a3 3 0 003-3V8a3 3 0 00-3-3H6a3 3 0 00-3 3v8a3 3 0 003 3z"
                ></path>
            </svg>
        </div>
        <span class="tracking-tight uppercase">Paytm</span>
    </a>

    <a
        href="#"
        id="genericLink"
        class="upi-button relative overflow-hidden group flex flex-col items-center justify-center gap-2 p-3.5 rounded-2xl font-bold text-[14px] transition-all duration-300 transform active:scale-95 bg-slate-800/50 backdrop-blur-md border border-white/10 text-white hover:border-emerald-500/50 hover:shadow-[0_0_15px_rgba(16,185,129,0.3)]"
    >
        <div
            class="p-2 rounded-xl bg-emerald-500/10 text-emerald-400 group-hover:scale-110 transition-transform"
        >
            <svg
                class="w-5 h-5"
                fill="none"
                stroke="currentColor"
                viewBox="0 0 24 24"
            >
                <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    d="M3 10h18M3 14h18m-9-4v8m-7 0h14a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v8a2 2 0 002 2z"
                ></path>
            </svg>
        </div>
        <span class="tracking-tight uppercase">UPI App</span>
    </a>
</div>

<style>
    #mobileAppsContainer {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 12px;
    }

    @media (min-width: 768px) {
        #mobileAppsContainer {
            display: none;
        }
    }

    .upi-button {
        transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
        padding: 14px;
        font-size: 14px;
    }
    .upi-button:hover {
        background: rgba(255, 255, 255, 0.05);
        transform: translateY(-2px);
    }
</style>

<script>
    window.addEventListener("updateUpiLink", (e: any) => {
        const upiLink = e.detail;
        const gpay = document.getElementById("gpayLink") as HTMLAnchorElement;
        const phonepe = document.getElementById(
            "phonepeLink",
        ) as HTMLAnchorElement;
        const paytm = document.getElementById("paytmLink") as HTMLAnchorElement;
        const generic = document.getElementById(
            "genericLink",
        ) as HTMLAnchorElement;

        if (gpay) gpay.href = upiLink.replace("upi://pay", "tez://upi/pay");
        if (phonepe)
            phonepe.href = upiLink.replace("upi://pay", "phonepe://pay");
        if (paytm) paytm.href = upiLink.replace("upi://pay", "paytmmp://pay");
        if (generic) generic.href = upiLink;
    });
</script>
